---
interface Props {
  title: string;
  description?: string;
}

import '../styles/global.css';

const { title, description = 'CX Mixer connects e-commerce brands through curated events, community, and podcast conversations built around real relationships and customer experience.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body>
  <div class="grain" aria-hidden="true"></div>

  <header class="hdr" id="hdr">
    <nav class="hdr__nav container" aria-label="Main navigation">
      <a href={`${base}`} class="hdr__logo" aria-label="CX Mixer Home">
        <img src={`${base}cxmixer_wordmark.svg`} alt="CX Mixer" class="hdr__logo-img" />
      </a>

      <button class="hdr__toggle" aria-label="Toggle navigation" aria-expanded="false" id="nav-toggle">
        <span></span><span></span><span></span>
      </button>

      <ul class="hdr__links" id="nav-links">
        <li><a href="#events">Events</a></li>
        <li><a href="#collective">Collective</a></li>
        <li><a href="#podcast">Podcast</a></li>
        <li><a href="#sponsors">Sponsors</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact" class="btn btn--primary hdr__cta">Let's Connect</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- ═══ FOOTER ═══ -->
  <footer class="ft">
    <div class="divider" style="height:4px;" aria-hidden="true"></div>
    <div class="ft__inner">
      <div class="container">
        <div class="ft__top">
          <div class="ft__brand">
            <img src={`${base}cxmixer_splash.svg`} alt="CX Mixer" class="ft__logo-img" />
            <p class="ft__tagline">Where e-commerce brands connect <em class="serif">beyond the pitch.</em></p>
            <div class="ft__socials">
              <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" aria-label="YouTube">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
              </a>
              <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" aria-label="Spotify">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
              </a>
              <a href="https://www.linkedin.com/company/cxmixer" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.4 20.5h-3.6v-5.6c0-1.3 0-3-1.9-3s-2.1 1.4-2.1 2.9v5.7H9.2V9h3.4v1.6h.1c.5-.9 1.6-1.9 3.4-1.9 3.6 0 4.3 2.4 4.3 5.5v6.3zM5.3 7.4a2.1 2.1 0 1 1 0-4.2 2.1 2.1 0 0 1 0 4.2zM7.1 20.5H3.5V9h3.6v11.5zM22.2 0H1.8C.8 0 0 .8 0 1.7v20.6c0 .9.8 1.7 1.8 1.7h20.4c1 0 1.8-.8 1.8-1.7V1.7c0-.9-.8-1.7-1.8-1.7z"/></svg>
              </a>
              <a href="https://www.instagram.com/cxmixer" target="_blank" rel="noopener" aria-label="Instagram">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zM12 0C8.7 0 8.3 0 7.1.1 5.8.1 4.9.3 4.1.6c-.8.3-1.5.7-2.2 1.4C1.3 2.6.9 3.3.6 4.1.3 4.9.1 5.8.1 7.1 0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.2 2.2.5 2.9.3.8.7 1.5 1.4 2.2.7.7 1.4 1.1 2.2 1.4.8.3 1.6.5 2.9.5C8.3 24 8.7 24 12 24s3.7 0 4.9-.1c1.3-.1 2.2-.2 2.9-.5.8-.3 1.5-.7 2.2-1.4.7-.7 1.1-1.4 1.4-2.2.3-.8.5-1.6.5-2.9.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.2-2.2-.5-2.9-.3-.8-.7-1.5-1.4-2.2-.7-.7-1.4-1.1-2.2-1.4C19.1.3 18.2.1 16.9.1 15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4A6.2 6.2 0 0 0 12 5.8zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm7.8-10.4a1.4 1.4 0 1 0-2.8 0 1.4 1.4 0 0 0 2.8 0z"/></svg>
              </a>
            </div>
          </div>

          <div class="ft__col">
            <h4>Navigate</h4>
            <ul>
              <li><a href="#events">Events</a></li>
              <li><a href="#podcast">Podcast</a></li>
              <li><a href="#collective">The Collective</a></li>
              <li><a href="#about">About</a></li>
              <li><a href="#contact">Contact</a></li>
            </ul>
          </div>

          <div class="ft__col">
            <h4>Connect</h4>
            <ul>
              <li><a href="#sponsors">Sponsor Opportunities</a></li>
              <li><a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener">YouTube</a></li>
              <li><a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener">Spotify</a></li>
            </ul>
          </div>

          <div class="ft__col">
            <h4>Listen</h4>
            <ul>
              <li><a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener">Spotify</a></li>
              <li><a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener">YouTube</a></li>
            </ul>
          </div>
        </div>

        <div class="ft__bottom">
          <p>&copy; {new Date().getFullYear()} CX Mixer. All rights reserved.</p>
          <p>A <a href="https://parcellab.com" target="_blank" rel="noopener">parcelLab</a> production.</p>
        </div>
      </div>
    </div>
  </footer>

  <style>
    /* ═══ HEADER — sharp, high contrast ═══ */
    .hdr {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 10000;
      background: rgba(26, 10, 46, 0.95);
      backdrop-filter: blur(16px) saturate(1.5);
      -webkit-backdrop-filter: blur(16px) saturate(1.5);
      border-bottom: 1px solid rgba(233, 30, 140, 0.15);
      transition: all var(--med) var(--ease);
    }

    .hdr.scrolled {
      background: rgba(26, 10, 46, 0.98);
      box-shadow: 0 2px 20px rgba(139, 49, 199, 0.2);
    }

    .hdr__nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
    }

    .hdr__logo { text-decoration: none; display: flex; }

    .hdr__logo-img {
      height: 44px;
      width: auto;
      object-fit: contain;
    }

    .hdr__links {
      display: flex;
      align-items: center;
      gap: 0.1rem;
      list-style: none;
    }

    .hdr__links a {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.8rem;
      color: rgba(255,255,255,0.65);
      padding: 0.45rem 0.85rem;
      border-radius: var(--r-pill);
      transition: all var(--fast) var(--ease);
      letter-spacing: -0.01em;
    }

    .hdr__links a:hover {
      color: #fff;
      background: rgba(255,255,255,0.08);
    }

    .hdr__cta {
      padding: 0.5rem 1.2rem !important;
      font-size: 0.78rem !important;
      margin-left: 0.5rem;
      color: #fff !important;
    }

    .hdr__toggle {
      display: none;
      flex-direction: column;
      gap: 6px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }

    .hdr__toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
      transition: all var(--fast) var(--ease);
    }

    @media (max-width: 960px) {
      .hdr__toggle { display: flex; }

      .hdr__links {
        position: fixed;
        top: 68px;
        left: 0;
        right: 0;
        height: calc(100dvh - 68px);
        flex-direction: column;
        background: #110620 !important;
        padding: var(--sp-xl) var(--sp-lg);
        gap: var(--sp-sm);
        transform: translateX(100%);
        transition: transform var(--med) var(--ease);
        z-index: 9999;
        overflow-y: auto;
      }

      .hdr__links.open { transform: translateX(0); }

      .hdr__links a { font-size: 1.3rem; padding: 0.75rem 1rem; color: rgba(255,255,255,0.7); }

      .hdr__toggle[aria-expanded="true"] span:nth-child(1) { transform: rotate(45deg) translate(5px, 6px); }
      .hdr__toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
      .hdr__toggle[aria-expanded="true"] span:nth-child(3) { transform: rotate(-45deg) translate(5px, -6px); }
    }

    /* ═══ FOOTER ═══ */
    .ft__inner {
      background: var(--ink);
      color: rgba(255,255,255,0.6);
      padding: var(--sp-2xl) 0 var(--sp-lg);
    }

    .ft__top {
      display: grid;
      grid-template-columns: 2.2fr 1fr 1fr 1fr;
      gap: var(--sp-xl);
      margin-bottom: var(--sp-xl);
    }

    .ft__logo-img { height: 70px; width: auto; object-fit: contain; margin-bottom: var(--sp-xs); }

    .ft__tagline { color: rgba(255,255,255,0.5); margin-top: var(--sp-sm); font-size: 0.95rem; max-width: 30ch; }
    .ft__tagline .serif { color: var(--coral-light); }

    .ft__socials { display: flex; gap: var(--sp-sm); margin-top: var(--sp-md); }
    .ft__socials a { color: rgba(255,255,255,0.35); transition: all var(--fast) var(--ease); display: flex; }
    .ft__socials a:hover { color: var(--coral); transform: translateY(-3px); }

    .ft__col h4 { font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: var(--sp-sm); color: rgba(255,255,255,0.3); }
    .ft__col ul { list-style: none; }
    .ft__col li { margin-bottom: 0.6rem; }
    .ft__col a { color: rgba(255,255,255,0.6); font-size: 0.9rem; font-weight: 400; transition: all var(--fast); }
    .ft__col a:hover { color: var(--coral); }

    .ft__bottom { border-top: 1px solid rgba(255,255,255,0.08); padding-top: var(--sp-lg); display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: rgba(255,255,255,0.3); }
    .ft__bottom a { color: var(--teal); }

    @media (max-width: 768px) {
      .ft__top { grid-template-columns: 1fr 1fr; gap: var(--sp-lg); }
      .ft__brand { grid-column: 1 / -1; }
      .ft__bottom { flex-direction: column; gap: var(--sp-xs); text-align: center; }
    }
  </style>

  <script>
    // Header scroll
    const hdr = document.getElementById('hdr');
    window.addEventListener('scroll', () => {
      hdr?.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });

    // Mobile nav
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      links?.classList.toggle('open');
    });

    // Close mobile nav on anchor click
    links?.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', () => {
        links?.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    // Scroll reveal
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
  </script>
</body>
</html>
