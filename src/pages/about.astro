---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const principles = [
  { text: 'Relationships beat transactions', icon: '&#x1F91D;' },
  { text: 'Community makes the industry better', icon: '&#x1F31F;' },
  { text: 'The best conversations happen off-stage', icon: '&#x1F4AC;' },
  { text: 'Good events should feel easy, not forced', icon: '&#x2728;' },
  { text: 'Smart people deserve spaces that don\'t take themselves too seriously', icon: '&#x1F60E;' },
];
---

<Base title="About CX Mixer | E-commerce Networking Community" description="CX Mixer was created to bring e-commerce people together in a way that feels more human, more useful, and a lot less transactional.">

  <!-- HERO -->
  <section class="page-hero section--dark">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="hero-shape hero-shape--1"></div>
      <div class="hero-shape hero-shape--2"></div>
    </div>
    <div class="container page-hero-content">
      <span class="badge reveal">About</span>
      <h1 class="reveal reveal-delay-1">Why CX Mixer exists</h1>
      <p class="page-hero-subtitle reveal reveal-delay-2">
        CX Mixer was created to bring e-commerce people together in a way that feels more human, more useful, and a lot less transactional.
      </p>
      <a href={`${base}collective/`} class="btn btn--primary reveal reveal-delay-3">Join the Community</a>
    </div>
  </section>

  <!-- ORIGIN -->
  <section class="section">
    <div class="container">
      <div class="origin-grid">
        <div class="reveal">
          <span class="section-label">Origin Story</span>
          <h2 class="text-balance">It started with a simple idea</h2>
          <p class="mb-md">
            CX Mixer started from a belief that the best part of this industry is the people in it. Conferences are full of smart brands and great conversations, but too often the real connection gets buried under schedules, badges, and back-to-back pitches.
          </p>
          <p>
            CX Mixer was built to create the kind of space where those real conversations could actually happen — no forced networking, no agenda beyond genuine connection, and no reason to check the clock.
          </p>
        </div>
        <div class="origin-visual reveal reveal-delay-1">
          <div class="origin-quote-card">
            <p>"The best part of the conference? The people you meet at the afterparty."</p>
            <span>— The idea behind CX Mixer</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="section section--teal">
    <div class="container text-center">
      <div class="reveal" style="max-width: 650px; margin: 0 auto;">
        <span class="section-label" style="color: #fff; justify-content: center;">Our Mission</span>
        <h2 class="mb-md">To connect e-commerce brands through events, media, and community that make the industry feel smaller, smarter, and more connected.</h2>
      </div>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section class="section">
    <div class="container">
      <div class="principles-grid">
        <div class="reveal">
          <span class="section-label">Our Approach</span>
          <h2 class="text-balance">What we believe</h2>
          <p>These aren't corporate values we wrote on a wall. They're the things that shape how we build events, pick guests, and run the community.</p>
        </div>
        <div class="principles-list">
          {principles.map((p, i) => (
            <div class={`principle-item reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <span class="principle-icon" set:html={p.icon} />
              <span class="principle-text">{p.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FOUNDER -->
  <section class="section section--dark">
    <div class="container">
      <div class="founder-grid">
        <div class="reveal">
          <span class="section-label" style="color: var(--orange);">The Host</span>
          <h2>Meet Larry Thoma</h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: var(--space-md);">
            Larry Thoma is the host and creator of CX Mixer, and a Post-Purchase Experience Expert at parcelLab. Working directly with some of the most creative and fast-growing DTC brands in e-commerce, Larry saw a gap — smart people attending the same conferences, having the same challenges, but never connecting in a way that felt real.
          </p>
          <p style="color: rgba(255,255,255,0.7);">
            CX Mixer was born from that frustration. Larry brings the energy, the guest list, and the belief that the industry is better when good people know each other.
          </p>
        </div>
        <div class="founder-card reveal reveal-delay-1">
          <div class="founder-avatar">
            <span class="founder-initials">LT</span>
          </div>
          <h3 style="color: #fff;">Larry Thoma</h3>
          <p class="founder-role">Host & Creator, CX Mixer</p>
          <p class="founder-role">Post-Purchase Experience Expert, parcelLab</p>
          <div class="founder-socials">
            <a href="https://www.linkedin.com/in/larrythoma" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.4 20.5h-3.6v-5.6c0-1.3 0-3-1.9-3s-2.1 1.4-2.1 2.9v5.7H9.2V9h3.4v1.6h.1c.5-.9 1.6-1.9 3.4-1.9 3.6 0 4.3 2.4 4.3 5.5v6.3zM5.3 7.4a2.1 2.1 0 1 1 0-4.2 2.1 2.1 0 0 1 0 4.2zM7.1 20.5H3.5V9h3.6v11.5zM22.2 0H1.8C.8 0 0 .8 0 1.7v20.6c0 .9.8 1.7 1.8 1.7h20.4c1 0 1.8-.8 1.8-1.7V1.7c0-.9-.8-1.7-1.8-1.7z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container text-center">
      <div class="reveal" style="max-width: 600px; margin: 0 auto;">
        <h2 class="mb-md text-balance">Want in?</h2>
        <p class="mb-lg">Whether you're looking for your next event, your next great conversation, or your next industry connection — CX Mixer is built to help you find it.</p>
        <div style="display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap;">
          <a href={`${base}collective/`} class="btn btn--primary">Join the Collective</a>
          <a href={`${base}events/`} class="btn btn--secondary">See Upcoming Events</a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    position: relative;
    padding: calc(72px + var(--space-3xl)) 0 var(--space-3xl);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero-shape--1 {
    width: 500px;
    height: 500px;
    background: rgba(74, 125, 255, 0.12);
    top: -150px;
    right: -100px;
  }

  .hero-shape--2 {
    width: 400px;
    height: 400px;
    background: rgba(31, 166, 160, 0.12);
    bottom: -100px;
    left: -50px;
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .page-hero-content h1 {
    color: #fff;
    margin: var(--space-md) 0;
  }

  .page-hero-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    margin-bottom: var(--space-lg);
  }

  /* ORIGIN */
  .origin-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .origin-quote-card {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    border-left: 4px solid var(--orange);
    box-shadow: 0 12px 30px rgba(19, 35, 60, 0.08);
  }

  .origin-quote-card p {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .origin-quote-card span {
    font-size: 0.85rem;
    color: rgba(42, 47, 54, 0.5);
    font-weight: 500;
  }

  /* PRINCIPLES */
  .principles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .principles-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .principle-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: #fff;
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .principle-item:hover {
    transform: translateX(4px);
    box-shadow: 0 8px 20px rgba(19, 35, 60, 0.06);
  }

  .principle-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .principle-text {
    font-weight: 500;
    color: var(--navy);
  }

  /* FOUNDER */
  .founder-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .founder-card {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .founder-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--orange));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
  }

  .founder-initials {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 2rem;
    color: #fff;
  }

  .founder-role {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .founder-socials {
    margin-top: var(--space-md);
  }

  .founder-socials a {
    color: rgba(255, 255, 255, 0.5);
    transition: color var(--duration-fast);
  }

  .founder-socials a:hover {
    color: var(--orange);
  }

  @media (max-width: 768px) {
    .origin-grid, .principles-grid, .founder-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
