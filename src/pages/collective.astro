---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const roles = [
  'CX Leaders',
  'E-commerce Operators',
  'Brand Marketers',
  'Retention & Loyalty Teams',
  'Tech & Ops Decision-Makers',
  'Founders & Digital Leaders',
];

const benefits = [
  { icon: '&#x1F3AB;', title: 'Early Access', desc: 'First invites to every CX Mixer event' },
  { icon: '&#x1F4AC;', title: 'Peer Conversations', desc: 'Community conversations and curated intros' },
  { icon: '&#x1F399;', title: 'Podcast Updates', desc: 'Access to episodes, clips, and behind-the-scenes content' },
  { icon: '&#x1F310;', title: 'Trusted Network', desc: 'A vetted circle of smart people in the industry' },
  { icon: '&#x2728;', title: 'Private Gatherings', desc: 'Invitations to curated, invite-only events' },
  { icon: '&#x1F4E3;', title: 'Get Featured', desc: 'Opportunities to share your ideas and expertise' },
];

const values = [
  { icon: '&#x1F49A;', text: 'Be generous' },
  { icon: '&#x1F3AF;', text: 'Keep it real' },
  { icon: '&#x1F4A1;', text: 'Share what\'s useful' },
  { icon: '&#x1F64F;', text: 'Respect the room' },
  { icon: '&#x1F91D;', text: 'Build relationships, not transactions' },
];
---

<Base title="The CX Collective | E-commerce Community" description="The CX Collective is where e-commerce brand leaders keep the conversation going between events. Join a trusted network of operators, marketers, and CX leaders.">

  <!-- HERO -->
  <section class="page-hero section--dark">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="hero-shape hero-shape--1"></div>
      <div class="hero-shape hero-shape--2"></div>
    </div>
    <div class="container page-hero-content">
      <span class="badge reveal">Community</span>
      <h1 class="reveal reveal-delay-1">The community side<br/>of CX Mixer</h1>
      <p class="page-hero-subtitle reveal reveal-delay-2">
        The CX Collective is where e-commerce brand leaders keep the conversation going between events.
      </p>
      <a href={`${base}contact/`} class="btn btn--primary reveal reveal-delay-3">Join the Collective</a>
    </div>
  </section>

  <!-- WHAT IS IT -->
  <section class="section">
    <div class="container" style="max-width: 750px;">
      <div class="reveal text-center">
        <span class="section-label" style="justify-content: center;">About the Collective</span>
        <h2 class="mb-md text-balance">More than an event list</h2>
        <p style="margin: 0 auto;">
          The CX Collective is a growing network of e-commerce operators, marketers, CX leaders, and brand builders who want a better way to connect. It's built for the people who want thoughtful conversations, useful relationships, and a community that feels a little more real than the average industry Slack or LinkedIn comment section.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="section" style="background: #fff;">
    <div class="container">
      <div class="who-grid">
        <div class="reveal">
          <span class="section-label">Who Belongs Here</span>
          <h2 class="text-balance">People shaping the customer journey</h2>
          <p>The Collective is designed for people shaping the customer journey and the brand experience — from CX and operations to retention, logistics, and digital growth.</p>
        </div>
        <div class="roles-list">
          {roles.map((role, i) => (
            <div class={`role-tag reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              {role}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal mb-xl">
        <span class="section-label" style="justify-content: center;">Membership</span>
        <h2>What members get</h2>
      </div>
      <div class="grid-3">
        {benefits.map((b, i) => (
          <div class={`benefit-card card reveal reveal-delay-${(i % 4) + 1}`}>
            <span class="benefit-icon" set:html={b.icon} />
            <h4>{b.title}</h4>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section section--dark">
    <div class="container">
      <div class="values-grid">
        <div class="reveal">
          <span class="section-label" style="color: var(--orange);">Values</span>
          <h2>How we show up</h2>
          <p style="color: rgba(255,255,255,0.7);">The best communities work because the people in them care more about helping than posturing. That's the energy here.</p>
        </div>
        <div class="values-list">
          {values.map((v, i) => (
            <div class={`value-item reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <span class="value-icon" set:html={v.icon} />
              <span class="value-text">{v.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- JOIN CTA -->
  <section class="section">
    <div class="container text-center">
      <div class="reveal" style="max-width: 600px; margin: 0 auto;">
        <h2 class="mb-md text-balance">Come join us</h2>
        <p class="mb-lg">
          If you're building in e-commerce and want to be part of a community that feels smart, welcoming, and actually enjoyable — you're in the right place.
        </p>
        <a href={`${base}contact/`} class="btn btn--primary">Apply to Join</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    position: relative;
    padding: calc(72px + var(--space-3xl)) 0 var(--space-3xl);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero-shape--1 {
    width: 500px;
    height: 500px;
    background: rgba(31, 166, 160, 0.2);
    top: -150px;
    right: -100px;
  }

  .hero-shape--2 {
    width: 400px;
    height: 400px;
    background: rgba(249, 115, 58, 0.12);
    bottom: -100px;
    left: -50px;
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .page-hero-content h1 {
    color: #fff;
    margin: var(--space-md) 0;
  }

  .page-hero-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    margin-bottom: var(--space-lg);
  }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .roles-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .role-tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(31, 166, 160, 0.08);
    border: 1px solid rgba(31, 166, 160, 0.2);
    border-radius: var(--radius-full);
    padding: 0.6rem 1.2rem;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .role-tag:hover {
    background: rgba(31, 166, 160, 0.15);
    transform: translateY(-2px);
  }

  .benefit-card {
    text-align: center;
  }

  .benefit-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .benefit-card h4 {
    margin-bottom: 0.25rem;
  }

  .benefit-card p {
    font-size: 0.9rem;
    color: rgba(42, 47, 54, 0.7);
    margin: 0 auto;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .values-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .value-item:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateX(4px);
  }

  .value-icon {
    font-size: 1.5rem;
  }

  .value-text {
    color: #fff;
    font-weight: 500;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .who-grid, .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
