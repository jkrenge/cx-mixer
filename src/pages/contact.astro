---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const inquiryTypes = [
  { label: 'General Inquiry', icon: '&#x1F4E8;' },
  { label: 'Event Questions', icon: '&#x1F3AB;' },
  { label: 'Sponsor Inquiry', icon: '&#x1F4BC;' },
  { label: 'Podcast Guest', icon: '&#x1F399;' },
  { label: 'Join the Collective', icon: '&#x1F91D;' },
];

