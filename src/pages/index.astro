  }

  /* ═══ ABOUT ═══ */
  .about__layout { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--sp-2xl); align-items: start; }
  .about__people { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-md); }
  .about__card { background: var(--surface); border-radius: var(--r-xl); padding: var(--sp-lg); text-align: center; border: 2px solid var(--border); text-decoration: none; color: inherit; display: block; transition: all var(--med) var(--ease); }
  .about__card:hover { transform: translateY(-6px); border-color: var(--magenta); box-shadow: 0 16px 40px rgba(233,30,140,0.12); }
  .about__avatar { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, var(--magenta), var(--purple)); padding: 3px; margin: 0 auto var(--sp-sm); box-shadow: 0 0 20px rgba(233,30,140,0.2); overflow: hidden; }
  .about__headshot { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .about__card h3 { font-size: 1.1rem; margin-bottom: 0.1rem; }
  .about__role { color: var(--mist); font-size: 0.8rem; margin-bottom: 0; }
  .about__bio { color: var(--text-muted); font-size: 0.82rem; margin-top: var(--sp-xs); line-height: 1.5; }
  .about__linkedin { display: inline-block; font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; color: var(--magenta); margin-top: var(--sp-sm); text-transform: uppercase; letter-spacing: 0.04em; }

  @media (max-width: 768px) { .about__layout { grid-template-columns: 1fr; } .about__people { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .about__people { grid-template-columns: 1fr; } }

  /* ═══ CONTACT ═══ */
  .contact__layout { display: grid; grid-template-columns: 1fr 1.4fr; gap: var(--sp-2xl); align-items: start; }
  .contact__links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .contact__link { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: var(--r-pill); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); font-weight: 500; font-size: 0.85rem; transition: all var(--fast) var(--ease); }
  .contact__link:hover { background: rgba(255,255,255,0.12); color: #fff; }
  .contact__form { display: flex; flex-direction: column; gap: var(--sp-md); }
  .contact__form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-md); }
  .contact__field { display: flex; flex-direction: column; gap: 0.35rem; }
  .contact__field label { font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; color: rgba(255,255,255,0.5); letter-spacing: 0.02em; }
  .contact__field input, .contact__field select, .contact__field textarea { font-family: var(--font-body); font-size: 0.9rem; padding: 0.7rem 1rem; border: 2px solid rgba(255,255,255,0.1); border-radius: var(--r-md); background: rgba(255,255,255,0.04); color: #fff; transition: all var(--fast) var(--ease); outline: none; }
  .contact__field input:focus, .contact__field select:focus, .contact__field textarea:focus { border-color: var(--magenta); box-shadow: 0 0 0 3px rgba(233,30,140,0.2), 0 0 20px rgba(233,30,140,0.08); }
  .contact__field input::placeholder, .contact__field textarea::placeholder { color: rgba(255,255,255,0.25); }
  .contact__field textarea { resize: vertical; min-height: 100px; }
  .contact__field select { appearance: none; background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23fff' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 1rem center; padding-right: 2.5rem; color: rgba(255,255,255,0.6); }
  .contact__field option { background: var(--ink); color: #fff; }
  .contact__success { display: flex; align-items: flex-start; gap: var(--sp-md); padding: var(--sp-md) var(--sp-lg); margin-bottom: var(--sp-md); background: rgba(127,255,0,0.08); border: 1px solid rgba(127,255,0,0.3); border-radius: var(--r-md); color: #fff; }
  .contact__success[hidden] { display: none; }
  .contact__success-icon { flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%; background: var(--neon, #7FFF00); color: var(--ink); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.1rem; }
  .contact__success strong { display: block; font-family: var(--font-display); font-size: 1rem; margin-bottom: 0.2rem; }
  .contact__success p { font-size: 0.85rem; color: rgba(255,255,255,0.65); margin: 0; }

  @media (max-width: 768px) { .contact__layout { grid-template-columns: 1fr; } .contact__form-row { grid-template-columns: 1fr; } }

  /* ═══ MOBILE SCROLL-SPY HOVER ═══ */
  @media (max-width: 768px) {
    .scroll-active {
      transform: translateY(-6px) rotate(-0.5deg) scale(1.02) !important;
      box-shadow: 0 16px 40px rgba(233, 30, 140, 0.2), 0 0 30px rgba(233, 30, 140, 0.08) !important;
      border-color: var(--magenta) !important;
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }
  }
</style>

<script>
  // ── Contact form success banner ──
  // FormSubmit redirects back to the site with ?sent=1 after a successful
  // submission. Show a confirmation banner and scroll the user to the form.
  if (new URLSearchParams(window.location.search).get('sent') === '1') {
    const banner = document.getElementById('contact-success');
    banner?.removeAttribute('hidden');
    // Hide the form below to avoid a confusing double-CTA
    document.getElementById('contact-form')?.setAttribute('style', 'display:none');
    // Scroll the contact section into view so users see the confirmation
    requestAnimationFrame(() => {
      document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      // Clean the URL so a refresh doesn't keep the banner up
      history.replaceState(null, '', window.location.pathname + window.location.hash);
    });
  }

  // ── Hero video click-to-play with sound ──
  const heroWrap = document.getElementById('hero-video-wrap');
  const heroVid = document.getElementById('hero-video') as HTMLVideoElement;

  const heroOverlay = document.getElementById('hero-video-overlay');
  const heroBadge = document.getElementById('hero-muted-badge');

  heroWrap?.addEventListener('click', () => {
    if (!heroVid) return;
    if (heroVid.muted) {
      heroVid.muted = false;
      heroVid.loop = false;
      heroVid.currentTime = 0;
      heroVid.controls = true;
      heroWrap.classList.add('playing');
      // Force-hide overlay and badge directly
      if (heroOverlay) heroOverlay.style.display = 'none';
      if (heroBadge) heroBadge.style.display = 'none';
    }
  });

  heroVid?.addEventListener('ended', () => {
    heroVid.muted = true;
    heroVid.loop = true;
    heroVid.controls = false;
    heroVid.play();
    heroWrap?.classList.remove('playing');
    // Restore overlay and badge
    if (heroOverlay) heroOverlay.style.display = '';
    if (heroBadge) heroBadge.style.display = '';
  });

  // ── Lightbox ──
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  document.querySelectorAll('.masonry img').forEach(img => {
    img.addEventListener('click', () => {
      const src = (img as HTMLImageElement).src;
      if (lightboxImg && lightbox) {
        lightboxImg.src = src;
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  function closeLightbox() {
    lightbox?.classList.remove('open');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelector('.lightbox__close')?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // ── Mobile scroll spy — highlight single closest element to center ──
  if (window.innerWidth <= 768) {
    const hoverTargets = Array.from(document.querySelectorAll(
      '.intro__card, .events__card, .yt-card, .quotes__card, .community__float'
    ));

    let active: Element | null = null;
    let ticking = false;

    function updateActiveCard() {
      const cy = window.innerHeight / 2;
      let closest: Element | null = null;
      let closestDist = Infinity;

      for (const el of hoverTargets) {
        const rect = el.getBoundingClientRect();
        const elCenter = rect.top + rect.height / 2;
        const dist = Math.abs(elCenter - cy);
        if (dist < closestDist) {
          closestDist = dist;
          closest = el;
        }
      }

      if (closest !== active) {
        active?.classList.remove('scroll-active');
        closest?.classList.add('scroll-active');
        active = closest;
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateActiveCard);
        ticking = true;
      }
    }, { passive: true });

    updateActiveCard();
  }
</script>
