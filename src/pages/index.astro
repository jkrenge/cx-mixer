---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const brands = [
  'Glossier', 'True Classic', 'Everlane', 'Vuori', 'Tommy John',
  'Dr. Squatch', 'Caraway', 'BaubleBar', '32 Degrees', 'Wyze',
  'Jaxxon', 'Olly', 'Simple Modern', 'Suit Shop', 'Taylor Stitch',
  'Fanatics Live', 'Nathan James', 'Carpe'
];

const episodes = [
  { title: 'How 8 CX Leaders Are Making AI Work — Right Now', guests: 'Glossier, Dr. Squatch, Caraway & more', tag: 'Bonus' },
  { title: '0 to 100: Building CX From Day One', guests: 'Breanna Moreno & Dan Kaparski', tag: 'Season 2' },
  { title: 'Quiet Luxury, Human CX', guests: 'Everlane & Vuori', tag: 'Season 2' },
];
---

<Base title="CX Mixer | E-commerce Events, Community & Podcast">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-shape hero-shape--1"></div>
      <div class="hero-shape hero-shape--2"></div>
      <div class="hero-shape hero-shape--3"></div>
      <div class="hero-grid-pattern"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-badge reveal">
        <span class="badge">Events &middot; Community &middot; Podcast</span>
      </div>
      <h1 class="hero-title reveal">
        Where e-commerce brands connect
        <span class="hero-highlight">beyond the pitch</span>
      </h1>
      <p class="hero-subtitle reveal reveal-delay-1">
        CX Mixer brings together brand leaders, operators, and industry friends through curated events, honest conversations, and content that makes the e-commerce world feel a little smaller and a lot more human.
      </p>
      <div class="hero-ctas reveal reveal-delay-2">
        <a href={`${base}collective/`} class="btn btn--primary">Join the Collective</a>
        <a href={`${base}events/`} class="btn btn--secondary">See Upcoming Events</a>
      </div>
      <div class="hero-listen reveal reveal-delay-3">
        <span class="hero-listen-label">Listen on</span>
        <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="hero-listen-link" aria-label="Spotify">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
        </a>
        <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="hero-listen-link" aria-label="YouTube">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
        </a>
        <a href="https://podcasts.apple.com/us/podcast/the-cx-mixer" target="_blank" rel="noopener" class="hero-listen-link" aria-label="Apple Podcasts">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm0 3.6c4.6 0 8.4 3.8 8.4 8.4 0 2.4-1 4.5-2.6 6.1-.3-.9-.7-1.6-1.2-2.3 1-1.1 1.6-2.4 1.6-3.8 0-3.4-2.8-6.2-6.2-6.2S5.8 8.6 5.8 12c0 1.4.6 2.8 1.6 3.8-.5.6-.9 1.4-1.2 2.3C4.6 16.5 3.6 14.4 3.6 12c0-4.6 3.8-8.4 8.4-8.4zm0 4.8c-2 0-3.6 1.6-3.6 3.6 0 1.2.6 2.3 1.5 2.9-.2.5-.3 1-.4 1.5-.1.6 0 1.2.1 1.7l.8 3.6c.2.7.8 1.3 1.6 1.3s1.4-.5 1.6-1.3l.8-3.6c.2-.5.2-1.1.1-1.7-.1-.5-.2-1-.4-1.5.9-.7 1.5-1.7 1.5-2.9 0-2-1.6-3.6-3.6-3.6zm0 2.4a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4z"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section" id="intro">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text reveal">
          <span class="section-label">What is CX Mixer</span>
          <h2 class="text-balance">Built for the people behind the brands</h2>
          <p class="mb-md">
            CX Mixer is where e-commerce leaders come to meet good people, share what's actually working, and build relationships that go beyond a badge scan. From curated conference-side events to podcast conversations and a growing community of operators — this is a space designed for connection without the noise.
          </p>
          <a href={`${base}collective/`} class="btn btn--teal">Explore the Community</a>
        </div>
        <div class="intro-features">
          <div class="feature-card reveal reveal-delay-1">
            <div class="feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4>Curated Events</h4>
            <p>Intimate gatherings at major e-commerce conferences</p>
          </div>
          <div class="feature-card reveal reveal-delay-2">
            <div class="feature-icon feature-icon--teal">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h4>Real Conversations</h4>
            <p>Podcast episodes with operators who share what actually works</p>
          </div>
          <div class="feature-card reveal reveal-delay-3">
            <div class="feature-icon feature-icon--orange">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h4>Trusted Community</h4>
            <p>A network of smart people who skip the pitch and share the playbook</p>
          </div>
          <div class="feature-card reveal reveal-delay-4">
            <div class="feature-icon feature-icon--navy">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/></svg>
            </div>
            <h4>No Sales Pitches</h4>
            <p>Connection without the noise — just great people doing great work</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTS PREVIEW -->
  <section class="section section--dark events-preview" id="events">
    <div class="container">
      <div class="events-header reveal">
        <span class="section-label" style="color: var(--orange);">Events</span>
        <h2>Meet up in real life</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 55ch;">
          From breakfast meetups to VIP lunches to late-night afterparties — CX Mixer events are designed to help e-commerce brands connect in a way that actually feels fun.
        </p>
      </div>
      <div class="events-cards grid-3">
        <div class="event-card reveal reveal-delay-1">
          <div class="event-card-type">
            <span class="badge badge--orange">Breakfast</span>
          </div>
          <h3>Morning Mixer</h3>
          <p class="event-card-desc">Start the conference day right. Coffee, conversation, and the kind of intros that actually lead somewhere.</p>
          <div class="event-card-meta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Coming Soon</span>
          </div>
        </div>
        <div class="event-card event-card--featured reveal reveal-delay-2">
          <div class="event-card-type">
            <span class="badge badge--orange">Happy Hour</span>
          </div>
          <h3>The Hangover Hangout</h3>
          <p class="event-card-desc">A casual mid-conference reset with great food, good people, and zero pressure. Meet fellow brand folks, recharge, and head back feeling slightly more human.</p>
          <div class="event-card-meta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Coming Soon</span>
          </div>
        </div>
        <div class="event-card reveal reveal-delay-3">
          <div class="event-card-type">
            <span class="badge badge--orange">VIP Dinner</span>
          </div>
          <h3>Late Night Conversations</h3>
          <p class="event-card-desc">An intimate dinner for brand leaders who want to go deeper. Curated guest list. No agenda beyond great food and real talk.</p>
          <div class="event-card-meta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Coming Soon</span>
          </div>
        </div>
      </div>
      <div class="text-center reveal" style="margin-top: var(--space-xl);">
        <a href={`${base}events/`} class="btn btn--outline-white">View All Events</a>
      </div>
    </div>
  </section>

  <!-- BRAND MARQUEE -->
  <section class="section brands-section">
    <div class="container text-center mb-lg reveal">
      <span class="section-label" style="justify-content: center;">Featured Brands</span>
      <h2>Good people. Great brands. Real conversations.</h2>
    </div>
    <div class="marquee-wrapper">
      <div class="marquee-track">
        {[...brands, ...brands].map((brand) => (
          <span class="brand-item">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMUNITY PREVIEW -->
  <section class="section community-preview">
    <div class="container">
      <div class="community-grid">
        <div class="community-visual reveal">
          <div class="community-card-stack">
            <div class="community-float-card community-float-card--1">
              <span class="float-emoji">&#x1F91D;</span>
              <span>New connection made</span>
            </div>
            <div class="community-float-card community-float-card--2">
              <span class="float-emoji">&#x1F399;</span>
              <span>New episode dropped</span>
            </div>
            <div class="community-float-card community-float-card--3">
              <span class="float-emoji">&#x1F389;</span>
              <span>Event invite sent</span>
            </div>
          </div>
        </div>
        <div class="community-text reveal reveal-delay-1">
          <span class="section-label">The CX Collective</span>
          <h2 class="text-balance">A community that sticks after the event ends</h2>
          <p class="mb-md">
            The CX Collective is the community side of CX Mixer. It's where brand leaders keep the conversations going, meet peers facing similar challenges, and tap into a trusted network of e-commerce operators who get it.
          </p>
          <p class="mb-lg" style="font-style: italic; color: var(--teal);">
            Think of it as your industry group chat — but with better people and fewer random pitches.
          </p>
          <a href={`${base}collective/`} class="btn btn--teal">Join the Collective</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PODCAST PREVIEW -->
  <section class="section section--dark podcast-preview">
    <div class="container">
      <div class="podcast-header reveal">
        <span class="section-label" style="color: var(--orange);">Podcast</span>
        <h2>Listen in</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 55ch;">
          Smart, practical conversations with the people building the customer experience from the inside. Never too polished. Always worth your time.
        </p>
      </div>
      <div class="grid-3">
        {episodes.map((ep, i) => (
          <div class={`podcast-card reveal reveal-delay-${i + 1}`}>
            <span class="badge">{ep.tag}</span>
            <h3>{ep.title}</h3>
            <p class="podcast-card-guests">{ep.guests}</p>
            <a href={`${base}podcast/`} class="podcast-card-play">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Listen Now
            </a>
          </div>
        ))}
      </div>
      <div class="text-center reveal" style="margin-top: var(--space-xl);">
        <div class="podcast-cta-row">
          <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="btn btn--white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
            Spotify
          </a>
          <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="btn btn--outline-white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
            YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section testimonials-section">
    <div class="container text-center">
      <div class="testimonials-grid reveal">
        <blockquote class="testimonial-card">
          <p>"CX Mixer feels like the part of the conference you actually remember."</p>
          <cite>— Brand CX Leader</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>"Real conversations, real relationships, zero forced networking."</p>
          <cite>— E-commerce Operator</cite>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>"Finally, a community that feels smart, welcoming, and actually enjoyable."</p>
          <cite>— DTC Brand Founder</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- SPONSORS TEASER -->
  <section class="section section--teal sponsors-teaser">
    <div class="container text-center">
      <div class="reveal">
        <h2 class="mb-md">Partner with the community brands want to be part of</h2>
        <p style="max-width: 55ch; margin: 0 auto var(--space-lg);">
          CX Mixer works with select sponsors who want to show up in the right rooms, support authentic connection, and build real visibility with e-commerce decision-makers.
        </p>
        <a href={`${base}sponsors/`} class="btn btn--white">Become a Sponsor</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section final-cta">
    <div class="container text-center">
      <div class="reveal">
        <h2 class="mb-md text-balance">Come hang with the good side of e-commerce</h2>
        <p style="max-width: 50ch; margin: 0 auto var(--space-lg); font-size: 1.1rem;">
          Come for the event. Stay for the people.
        </p>
        <div class="hero-ctas" style="justify-content: center;">
          <a href={`${base}collective/`} class="btn btn--primary">Join the Collective</a>
          <a href={`${base}events/`} class="btn btn--secondary">Get Event Updates</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 72px;
    overflow: hidden;
    background: var(--navy);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero-shape--1 {
    width: 600px;
    height: 600px;
    background: rgba(31, 166, 160, 0.2);
    top: -200px;
    right: -100px;
    animation: float-slow 20s ease-in-out infinite;
  }

  .hero-shape--2 {
    width: 400px;
    height: 400px;
    background: rgba(249, 115, 58, 0.15);
    bottom: -100px;
    left: -50px;
    animation: float-slow 25s ease-in-out infinite reverse;
  }

  .hero-shape--3 {
    width: 300px;
    height: 300px;
    background: rgba(74, 125, 255, 0.1);
    top: 40%;
    left: 50%;
    animation: float-slow 18s ease-in-out infinite 5s;
  }

  .hero-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  @keyframes float-slow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: var(--space-3xl) 0;
    max-width: 800px;
  }

  .hero-badge {
    margin-bottom: var(--space-md);
  }

  .hero-badge .badge {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.7rem;
  }

  .hero-title {
    color: #fff;
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }

  .hero-highlight {
    display: block;
    background: linear-gradient(135deg, var(--orange), var(--teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    max-width: 55ch;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .hero-ctas .btn--secondary {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .hero-ctas .btn--secondary:hover {
    background: #fff;
    color: var(--navy);
  }

  .hero-listen {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-listen-label {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .hero-listen-link {
    color: rgba(255, 255, 255, 0.4);
    transition: all var(--duration-fast) var(--ease-out);
    display: flex;
  }

  .hero-listen-link:hover {
    color: var(--orange);
    transform: scale(1.15);
  }

  /* ===== INTRO ===== */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .intro-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }

  .feature-card {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(19, 35, 60, 0.08);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: rgba(19, 35, 60, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
    color: var(--navy);
  }

  .feature-icon--teal { background: rgba(31, 166, 160, 0.1); color: var(--teal); }
  .feature-icon--orange { background: rgba(249, 115, 58, 0.1); color: var(--orange); }
