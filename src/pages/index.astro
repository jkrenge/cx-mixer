<style>
  /* ═══ HERO ═══ */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 68px;
    overflow: hidden;
    background: linear-gradient(135deg, #1A0A2E 0%, #2D0845 50%, #1A0A2E 100%);
  }

  .hero__bg { position: absolute; inset: 0; overflow: hidden; }

  .hero__orb { position: absolute; border-radius: 50%; filter: blur(100px); will-change: transform; }
  .hero__orb--1 { width: 700px; height: 700px; background: radial-gradient(circle, rgba(233,30,140,0.35), transparent 70%); top: -250px; right: -150px; animation: float 20s ease-in-out infinite; }
  .hero__orb--2 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(83,198,214,0.25), transparent 70%); bottom: -150px; left: -100px; animation: float 25s ease-in-out infinite reverse; }
  .hero__orb--3 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(139,49,199,0.25), transparent 70%); top: 45%; left: 55%; animation: float 18s ease-in-out infinite 3s; }

  .hero__grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 80px 80px; mask-image: radial-gradient(ellipse at 30% 50%, black 30%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse at 30% 50%, black 30%, transparent 75%); }

  .hero__deco { position: absolute; pointer-events: none; }
  .hero__deco--star { font-size: 3rem; color: var(--magenta); opacity: 0.35; top: 18%; right: 12%; animation: pulse-glow 4s ease-in-out infinite; }
  .hero__deco--cross { font-family: var(--font-display); font-size: 4rem; font-weight: 900; color: var(--neon); opacity: 0.15; bottom: 25%; right: 22%; animation: spin-slow 40s linear infinite reverse; }
  .hero__deco--ring { width: 180px; height: 180px; border: 3px solid var(--cyan); border-radius: 50%; opacity: 0.12; top: 30%; right: 5%; animation: spin-slow 50s linear infinite; }
  .hero__deco--logo { width: 320px; height: auto; opacity: 0.06; top: 50%; right: -40px; transform: translateY(-50%) rotate(-8deg); animation: float 15s ease-in-out infinite; filter: blur(1px); }

  .hero__layout { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr auto; gap: var(--sp-xl); align-items: center; padding-top: var(--sp-3xl); padding-bottom: var(--sp-3xl); }
  .hero__content { max-width: 700px; }

  .hero__video { flex-shrink: 0; }
  .hero__video-el { width: 220px; height: auto; border-radius: var(--r-xl); box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 40px rgba(233,30,140,0.15); border: 2px solid rgba(255,255,255,0.1); }

  @media (max-width: 960px) {
    .hero__layout { grid-template-columns: 1fr; }
    .hero__video { display: none; }
  }
  .hero__eyebrow { margin-bottom: var(--sp-md); }
  .hero__title { color: #fff; margin-bottom: var(--sp-md); line-height: 1.0; }
  .hero__em { display: block; background: linear-gradient(135deg, var(--magenta) 0%, var(--neon) 50%, var(--cyan) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; padding-top: 0.1em; }
  .hero__em .serif { font-size: 1.1em; }
  .hero__sub { color: rgba(255,255,255,0.55); font-size: 1.1rem; line-height: 1.75; margin-bottom: var(--sp-lg); max-width: 52ch; }
  .hero__actions { display: flex; gap: var(--sp-sm); flex-wrap: wrap; margin-bottom: var(--sp-xl); }
  .hero__listen { display: flex; align-items: center; gap: var(--sp-sm); }
  .hero__listen-label { color: rgba(255,255,255,0.3); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; font-family: var(--font-display); }
  .hero__listen-icon { color: rgba(255,255,255,0.3); transition: all var(--fast) var(--ease-bounce); display: flex; }
  .hero__listen-icon:hover { color: var(--coral); transform: scale(1.2) translateY(-2px); }

  .hero__scroll { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.25); font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; }
  .hero__scroll-line { width: 1.5px; height: 40px; background: linear-gradient(to bottom, var(--magenta), transparent); animation: pulse-glow 2s ease-in-out infinite; }

  /* ═══ INTRO ═══ */
  .intro__layout { display: grid; grid-template-columns: 1.1fr 1fr; gap: var(--sp-2xl); align-items: start; }
  .intro__cards { display: flex; flex-direction: column; gap: 0.75rem; }
  .intro__card { display: flex; align-items: flex-start; gap: var(--sp-md); padding: var(--sp-md) var(--sp-lg); background: var(--surface); border-radius: var(--r-lg); border: 2px solid var(--border); transition: all var(--med) var(--ease); cursor: default; }
  .intro__card:hover { border-color: var(--magenta); transform: translateX(8px) rotate(-0.5deg); box-shadow: -8px 8px 0 var(--magenta), 0 0 30px rgba(233,30,140,0.15); }
  .intro__card-icon { font-size: 1.8rem; flex-shrink: 0; margin-top: 2px; }
  .intro__card h4 { margin-bottom: 0.1rem; font-size: 1.05rem; }
  .intro__card p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.5; }

  @media (max-width: 768px) { .intro__layout { grid-template-columns: 1fr; gap: var(--sp-xl); } }

  /* ═══ EVENTS ═══ */
  .events__head { margin-bottom: var(--sp-xl); }
  .events__head .section-label::before { background: var(--teal); }
  .events__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-md); }
  .events__card { background: rgba(255,255,255,0.03); border: 2px solid rgba(255,255,255,0.08); border-radius: var(--r-xl); padding: var(--sp-lg); position: relative; overflow: hidden; transition: all var(--med) var(--ease); }
  .events__card:hover { border-color: var(--magenta); transform: translateY(-8px) rotate(-1deg); box-shadow: 0 20px 50px rgba(233,30,140,0.2), 0 0 60px rgba(233,30,140,0.08); }
  .events__card--featured { border-color: var(--coral); background: rgba(255,94,53,0.06); }
  .events__card-num { font-family: var(--font-display); font-weight: 900; font-size: 5rem; color: rgba(255,255,255,0.04); position: absolute; top: -0.5rem; right: 1rem; line-height: 1; pointer-events: none; }
  .events__card h3 { color: #fff; font-size: 1.3rem; margin: 0.6rem 0 0.4rem; }
  .events__card p { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-bottom: var(--sp-md); }
  .events__card-tag { font-family: var(--font-display); font-weight: 700; font-size: 0.75rem; color: var(--teal); text-transform: uppercase; letter-spacing: 0.08em; }

  @media (max-width: 768px) { .events__grid { grid-template-columns: 1fr; } }

  /* ═══ BRANDS ═══ */
  .brands { padding-bottom: var(--sp-xl); overflow: hidden; }
  .brands__pill { font-family: var(--font-display); font-weight: 700; font-size: 0.95rem; color: var(--ink); padding: 0.55rem 1.4rem; margin: 0 0.35rem; background: var(--surface); border-radius: var(--r-pill); border: 2px solid var(--border); white-space: nowrap; transition: all var(--fast) var(--ease); letter-spacing: -0.01em; }
  .brands__pill:hover { border-color: var(--coral); color: var(--coral); transform: scale(1.05); }
  .brands__pill--alt { background: var(--ink); color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.1); }
  .brands__pill--alt:hover { border-color: var(--teal); color: var(--teal); }

  /* ═══ MASONRY (CSS columns) ═══ */
  .masonry-section { overflow: hidden; }

  .masonry {
    columns: 5;
    column-gap: 0.6rem;
  }

  .masonry img {
    width: 100%;
    display: block;
    border-radius: var(--r-md);
    margin-bottom: 0.6rem;
    break-inside: avoid;
    transition: all var(--med) var(--ease);
    cursor: pointer;
  }

  .masonry img:hover {
    transform: scale(1.04) rotate(-0.5deg);
    box-shadow: 0 12px 40px rgba(233, 30, 140, 0.25);
    z-index: 1;
    position: relative;
  }

  .masonry__featured {
    border: 3px solid var(--magenta) !important;
    box-shadow: 0 0 30px rgba(233, 30, 140, 0.25) !important;
  }

  .masonry__featured:hover {
    box-shadow: 0 0 50px rgba(233, 30, 140, 0.4), 0 12px 40px rgba(233, 30, 140, 0.25) !important;
  }

  @media (max-width: 1024px) {
    .masonry { columns: 4; }
  }

  @media (max-width: 768px) {
    .masonry { columns: 3; }
  }

  @media (max-width: 480px) {
    .masonry { columns: 2; column-gap: 0.4rem; }
    .masonry img { margin-bottom: 0.4rem; border-radius: var(--r-sm); }
  }

  /* ═══ COMMUNITY ═══ */
  .community__layout { display: grid; grid-template-columns: 1fr 1.1fr; gap: var(--sp-2xl); align-items: center; }
  .community__visual { position: relative; height: 380px; }
  .community__blob { position: absolute; width: 260px; height: 260px; border-radius: 50%; background: linear-gradient(135deg, rgba(0,212,170,0.15), rgba(124,58,237,0.1)); filter: blur(60px); top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .community__float { position: absolute; background: var(--surface); border-radius: var(--r-lg); padding: 0.85rem 1.2rem; display: flex; align-items: center; gap: 0.75rem; font-family: var(--font-display); font-weight: 600; font-size: 0.85rem; box-shadow: 0 12px 40px rgba(10,15,28,0.12); border: 2px solid var(--border); animation: float 6s ease-in-out infinite; }
  .community__float span:first-child { font-size: 1.4rem; }
  .community__float--1 { top: 15%; left: 5%; }
