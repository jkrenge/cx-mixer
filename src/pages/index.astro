---
import Base from '../layouts/Base.astro';

const brands = [
  'Glossier', 'True Classic', 'Everlane', 'Vuori', 'Tommy John',
  'Dr. Squatch', 'Caraway', 'BaubleBar', '32 Degrees', 'Wyze',
  'Jaxxon', 'Olly', 'Simple Modern', 'Suit Shop', 'Taylor Stitch',
  'Fanatics Live', 'Nathan James', 'Carpe'
];

// Season 1 (oldest → newest)
const season1 = [
  { id: 'aq8Hb2MnP4I', title: 'The Customer ISN\'T Always Right', guests: 'Tommy John & True Classic', ep: 'Ep 1' },
  { id: 'TuKgoOwyAuw', title: 'The Impact A Small CX Team Can Have On A Brand', guests: 'Carpe & Caraway Home', ep: 'Ep 2' },
  { id: 'crH4nntwK4c', title: 'From Cart to Community: How Brands Build CX That Connects', guests: 'Glossier & BaubleBar', ep: 'Ep 3' },
  { id: 'L9cUukPj3vM', title: 'Everywhere All at Once: Mastering CX Across Channels', guests: 'Wyze & Olly', ep: 'Ep 4' },
  { id: '9BSsYgxozNc', title: 'Gold Chains and Soap Bars: Female CX Bosses Revolutionizing Men\'s Brands', guests: 'Jaxxon & Dr. Squatch', ep: 'Ep 5' },
];

// Season 2 + Bonus (oldest → newest)
const season2 = [
  { id: 's2wmJtTex5Y', title: 'From Cart to Closet to Cup Holder: CX For Modern Essentials', guests: 'Simple Modern & 32 Degrees', ep: 'Ep 6' },
  { id: '5wGqugOohGE', title: 'The Fine Print: Fighting Fraud Without Losing Customers', guests: 'Fanatics Live & Nathan James', ep: 'Ep 7' },
  { id: 'D-l60gX69Ss', title: 'The Modern Man\'s Journey: From Rugged to Refined', guests: 'Suit Shop & Taylor Stitch', ep: 'Ep 8' },
  { id: 'YqDJSbTcUyw', title: 'Quiet Luxury, Human CX: Premium Experiences Without the Snob Factor', guests: 'Everlane & Vuori', ep: 'Ep 9' },
  { id: 'OWO2pbKlBDI', title: '0 to 100: Building CX From Day One', guests: 'Breanna Moreno & Dan Kaparski', ep: 'Ep 10' },
  { id: 'kd8OWquqcE4', title: 'How 8 CX Leaders Are Making AI Work — Right Now', guests: 'Glossier, Dr. Squatch, Caraway & more', ep: 'Bonus' },
];

const features = [
  { icon: '&#x26A1;', title: 'Curated Events', desc: 'Intimate gatherings at the industry\'s biggest moments' },
  { icon: '&#x1F399;', title: 'Real Conversations', desc: 'Operators sharing what actually works — no script' },
  { icon: '&#x1F310;', title: 'Trusted Community', desc: 'A network that skips the pitch and shares the playbook' },
  { icon: '&#x2728;', title: 'Zero Sales Energy', desc: 'Connection without the noise. Just great people, period.' },
];

const values = [
  { icon: '&#x1F49A;', text: 'Be generous' },
  { icon: '&#x1F3AF;', text: 'Keep it real' },
  { icon: '&#x1F4A1;', text: 'Share what\'s useful' },
  { icon: '&#x1F64F;', text: 'Respect the room' },
  { icon: '&#x1F91D;', text: 'Build relationships, not transactions' },
];

const inquiryTypes = ['General Inquiry', 'Event Questions', 'Sponsor Inquiry', 'Podcast Guest', 'Join the Collective'];
---

<Base title="CX Mixer | E-commerce Events, Community & Podcast">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
      <div class="hero__orb hero__orb--3"></div>
      <div class="hero__grid"></div>
      <div class="hero__deco hero__deco--star">&#x2726;</div>
      <div class="hero__deco hero__deco--cross">+</div>
      <div class="hero__deco hero__deco--ring"></div>
      <img src={`${import.meta.env.BASE_URL}cxmixer_splash.svg`} alt="" class="hero__deco hero__deco--logo" aria-hidden="true" />
    </div>

    <div class="container hero__layout">
      <div class="hero__content">
        <div class="hero__eyebrow" style="animation: slide-up 0.6s var(--ease) both;">
          <span class="badge badge--outline">Events &middot; Community &middot; Podcast</span>
        </div>

        <h1 class="hero__title" style="animation: slide-up 0.7s var(--ease) 0.1s both;">
          Where e&#8209;commerce brands connect
          <span class="hero__em"><em class="serif">beyond the pitch</em></span>
        </h1>

        <p class="hero__sub" style="animation: slide-up 0.7s var(--ease) 0.2s both;">
          CX Mixer brings together brand leaders, operators, and industry friends through curated events, honest conversations, and content that makes the e-commerce world feel a little smaller and a lot more human.
        </p>

        <div class="hero__actions" style="animation: slide-up 0.7s var(--ease) 0.3s both;">
          <a href="#collective" class="btn btn--primary">Join the Collective</a>
          <a href="#events" class="btn btn--ghost">See Upcoming Events</a>
        </div>

        <div class="hero__listen" style="animation: fade-in 1s var(--ease) 0.6s both;">
          <span class="hero__listen-label">Listen on</span>
        <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="hero__listen-icon" aria-label="Spotify">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
        </a>
        <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="hero__listen-icon" aria-label="YouTube">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
        </a>
        </div>
      </div>

      <!-- Hero Video -->
      <div class="hero__video" style="animation: scale-in 0.8s var(--ease) 0.4s both;">
        <video autoplay muted loop playsinline class="hero__video-el">
          <source src={`${import.meta.env.BASE_URL}videos/hypevideo.mp4`} type="video/mp4" />
        </video>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true" style="animation: fade-in 1.2s var(--ease) 1s both;">
      <span>Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══ INTRO ═══ -->
  <section class="section intro">
    <div class="container">
      <div class="intro__layout">
        <div class="intro__text reveal">
          <span class="section-label">What is CX Mixer</span>
          <h2 class="text-balance">Built for the people <em class="serif">behind</em> the brands</h2>
          <p class="mb-md">
            CX Mixer is where e-commerce leaders come to meet good people, share what's actually working, and build relationships that go beyond a badge scan. From curated conference-side events to podcast conversations and a growing community of operators — this is a space designed for connection without the noise.
          </p>
          <a href="#collective" class="btn btn--teal">Explore the Community</a>
        </div>
        <div class="intro__cards">
          {features.map((f, i) => (
            <div class={`intro__card reveal reveal-delay-${i + 1}`}>
              <span class="intro__card-icon" set:html={f.icon} />
              <div>
                <h4>{f.title}</h4>
                <p>{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EVENTS ═══ -->
  <section class="section section--dark events" id="events">
    <div class="divider" style="position:absolute;top:0;left:0;right:0;height:4px;" aria-hidden="true"></div>
    <div class="container">
      <div class="events__head reveal">
        <span class="section-label" style="color: var(--teal);">Events</span>
        <h2>Meet up in <em class="serif">real life</em></h2>
        <p style="color: rgba(255,255,255,0.55); max-width: 50ch;">
          From breakfast meetups to VIP dinners — CX Mixer events are designed to help e-commerce brands connect in a way that actually feels fun. No pitches. Just brands.
        </p>
      </div>
      <div class="events__grid">
        <div class="events__card reveal reveal-delay-1">
          <div class="events__card-num" aria-hidden="true">01</div>
          <span class="badge badge--coral">Breakfast</span>
          <h3>Morning Mixer</h3>
          <p>Start the conference day right. Coffee, conversation, and the kind of intros that actually lead somewhere.</p>
          <span class="events__card-tag">Coming Soon</span>
        </div>
        <div class="events__card events__card--featured reveal reveal-delay-2">
          <div class="events__card-num" aria-hidden="true">02</div>
          <span class="badge badge--coral">Happy Hour</span>
          <h3>The Hangover Hangout</h3>
          <p>A casual mid-conference reset with great food, good people, and zero pressure. Meet fellow brand folks and recharge.</p>
          <span class="events__card-tag">Coming Soon</span>
        </div>
        <div class="events__card reveal reveal-delay-3">
          <div class="events__card-num" aria-hidden="true">03</div>
          <span class="badge badge--coral">VIP Dinner</span>
          <h3>Late Night Conversations</h3>
          <p>An intimate dinner for brand leaders. Curated guest list. No agenda beyond great food and real talk.</p>
          <span class="events__card-tag">Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BRAND MARQUEE ═══ -->
  <section class="section brands">
    <div class="container text-center mb-lg reveal">
      <h2>Good people. Great brands.<br/><em class="serif">Real conversations.</em></h2>
    </div>
    <div class="marquee-wrapper">
      <div class="marquee-track">
        {[...brands, ...brands].map((brand) => (
          <span class="brands__pill">{brand}</span>
        ))}
      </div>
    </div>
    <div class="marquee-wrapper" style="margin-top: 0.75rem;">
      <div class="marquee-track" style="animation-direction: reverse; animation-duration: 35s;">
        {[...brands, ...brands].reverse().map((brand) => (
          <span class="brands__pill brands__pill--alt">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PHOTO MASONRY ═══ -->
  <section class="section masonry-section">
    <div class="container text-center mb-lg reveal">
      <span class="section-label" style="justify-content: center;">The Vibe</span>
      <h2>What happens when the <em class="serif">right people</em> end up in the same room</h2>
    </div>
    <div class="container">
      <div class="masonry reveal">
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0329.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0460.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0353.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0832.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0438.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF1079.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0504.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0369.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSC02157.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0643.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSC02113.webp`} alt="CX Mixer event — featured" loading="lazy" class="masonry__featured" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0559.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0780.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0468.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF1153.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF1323.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSC02163.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSC02188.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0479.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF1207.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF0657.webp`} alt="CX Mixer event" loading="lazy" />
        <img src={`${import.meta.env.BASE_URL}photos/DSCF1335.webp`} alt="CX Mixer event" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ═══ COLLECTIVE ═══ -->
  <section class="section community" id="collective">
    <div class="container">
      <div class="community__layout">
        <div class="community__visual reveal">
          <div class="community__blob" aria-hidden="true"></div>
          <div class="community__float community__float--1">
            <span>&#x1F91D;</span> New connection made
          </div>
          <div class="community__float community__float--2">
            <span>&#x1F399;</span> New episode dropped
          </div>
          <div class="community__float community__float--3">
            <span>&#x1F389;</span> Event invite sent
          </div>
        </div>
        <div class="community__text reveal reveal-delay-1">
          <span class="section-label">The CX Collective</span>
          <h2 class="text-balance">A community that sticks <em class="serif">after</em> the event ends</h2>
          <p class="mb-md">
            The CX Collective is the community side of CX Mixer. It's where brand leaders keep the conversations going, meet peers facing similar challenges, and tap into a trusted network of e-commerce operators who get it.
          </p>
          <p class="community__quote mb-lg">
            Think of it as your industry group chat — but with better people and fewer random pitches.
          </p>
          <div class="community__values">
            {values.map((v) => (
              <div class="community__value">
                <span set:html={v.icon} />
                <span>{v.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PODCAST ═══ -->
  <section class="section section--dark podcast" id="podcast">
    <div class="divider" style="position:absolute;top:0;left:0;right:0;height:4px;" aria-hidden="true"></div>
    <div class="container">
      <div class="podcast__head reveal">
        <span class="section-label" style="color: var(--teal);">Podcast</span>
        <h2>Watch & Listen <em class="serif">in</em></h2>
        <p style="color: rgba(255,255,255,0.55); max-width: 50ch;">
          Smart, practical conversations with the people building the customer experience from the inside. Never too polished. Always worth your time.
        </p>
      </div>

      <!-- Season 1 -->
      <h3 class="podcast__season reveal" style="color: var(--cyan); margin-bottom: var(--sp-md);">Season 1</h3>
      <div class="podcast__grid reveal">
        {season1.map((ep) => (
          <div class="yt-card">
            <a href={`https://youtu.be/${ep.id}`} target="_blank" rel="noopener" class="yt-card__thumb">
              <img src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`} alt={ep.title} loading="lazy" />
              <div class="yt-card__play">
                <svg width="48" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
              </div>
            </a>
            <div class="yt-card__info">
              <span class="badge badge--dark">{ep.ep}</span>
              <h4>{ep.title}</h4>
              <p>{ep.guests}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Season 2 + Bonus -->
      <h3 class="podcast__season reveal" style="color: var(--cyan); margin-top: var(--sp-xl); margin-bottom: var(--sp-md);">Season 2</h3>
      <div class="podcast__grid reveal">
        {season2.map((ep) => (
          <div class="yt-card">
            <a href={`https://youtu.be/${ep.id}`} target="_blank" rel="noopener" class="yt-card__thumb">
              <img src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`} alt={ep.title} loading="lazy" />
              <div class="yt-card__play">
                <svg width="48" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
              </div>
            </a>
            <div class="yt-card__info">
              <span class="badge badge--dark">{ep.ep}</span>
              <h4>{ep.title}</h4>
              <p>{ep.guests}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center reveal" style="margin-top: var(--sp-xl);">
        <div class="podcast__ctas">
          <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="btn btn--white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
            Spotify
          </a>
          <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="btn btn--ghost">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
            YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="section quotes">
    <div class="container">
      <div class="quotes__grid reveal">
        <blockquote class="quotes__card">
          <div class="quotes__mark" aria-hidden="true">&ldquo;</div>
          <p>CX Mixer feels like the part of the conference you actually remember.</p>
          <cite>Brand CX Leader</cite>
        </blockquote>
        <blockquote class="quotes__card quotes__card--accent">
          <div class="quotes__mark" aria-hidden="true">&ldquo;</div>
          <p>Real conversations, real relationships, zero forced networking.</p>
          <cite>E-commerce Operator</cite>
        </blockquote>
        <blockquote class="quotes__card">
          <div class="quotes__mark" aria-hidden="true">&ldquo;</div>
          <p>Finally, a community that feels smart, welcoming, and actually enjoyable.</p>
          <cite>DTC Brand Founder</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══ SPONSORS ═══ -->
  <section class="section section--coral sponsor-tease" id="sponsors">
    <div class="sponsor-tease__deco" aria-hidden="true">&#x2726;</div>
    <div class="container">
      <div class="sponsor__layout reveal">
        <div class="sponsor__text">
          <h2 class="mb-md">Partner with the community brands <em class="serif">want</em> to be part of</h2>
          <p style="opacity: 0.85; margin-bottom: var(--sp-lg);">
            CX Mixer works with select sponsors who want to show up in the right rooms, support authentic connection, and build real visibility with e-commerce decision-makers.
          </p>
          <a href="#contact" class="btn btn--white">Become a Sponsor</a>
        </div>
        <div class="sponsor__video">
          <video controls playsinline preload="metadata" class="sponsor__video-el" poster={`${import.meta.env.BASE_URL}photos/DSCF0643.webp`}>
            <source src={`${import.meta.env.BASE_URL}videos/sponsorvideo.mp4`} type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
