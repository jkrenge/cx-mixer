---
import Base from '../layouts/Base.astro';
import yaml from 'js-yaml';

// Load all content from YAML (Vite raw import)
import rawYaml from '../content/site.yaml?raw';
const site = yaml.load(rawYaml) as any;

// Destructure for template use
const { hero, intro, events: eventsData, brands: brandsData, gallery, collective, podcast, quotes, sponsors, about, contact, links } = site;
const season1 = podcast.season1;
const season2 = podcast.season2;
---

<Base title={site.meta.title} description={site.meta.description}>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
      <div class="hero__orb hero__orb--3"></div>
      <div class="hero__grid"></div>
      <div class="hero__deco hero__deco--star">&#x2726;</div>
      <div class="hero__deco hero__deco--cross">+</div>
      <div class="hero__deco hero__deco--ring"></div>
      <img src={`${import.meta.env.BASE_URL}cxmixer_splash.svg`} alt="" class="hero__deco hero__deco--logo" aria-hidden="true" />
    </div>

    <div class="container hero__layout">
      <div class="hero__content">
        <div class="hero__eyebrow" style="animation: slide-up 0.6s var(--ease) both;">
          <span class="badge badge--outline">{hero.badge}</span>
        </div>

        <h1 class="hero__title" style="animation: slide-up 0.7s var(--ease) 0.1s both;">
          {hero.title}
          <span class="hero__em"><em class="serif">{hero.title_em}</em></span>
        </h1>

        <p class="hero__sub" style="animation: slide-up 0.7s var(--ease) 0.2s both;">
          {hero.subtitle}
        </p>

        <div class="hero__actions" style="animation: slide-up 0.7s var(--ease) 0.3s both;">
          <a href="#collective" class="btn btn--primary">{hero.cta_primary}</a>
          <a href="#events" class="btn btn--ghost">{hero.cta_secondary}</a>
        </div>

        <div class="hero__listen" style="animation: fade-in 1s var(--ease) 0.6s both;">
          <span class="hero__listen-label">{hero.listen_label}</span>
        <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="hero__listen-icon" aria-label="Spotify">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
        </a>
        <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="hero__listen-icon" aria-label="YouTube">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
        </a>
        </div>
      </div>

      <!-- Hero Video -->
      <div class="hero__video" style="animation: scale-in 0.8s var(--ease) 0.4s both;">
        <div class="hero__video-wrap" id="hero-video-wrap">
          <video autoplay muted loop playsinline class="hero__video-el" id="hero-video">
            <source src={`${import.meta.env.BASE_URL}videos/hypevideo.mp4`} type="video/mp4" />
          </video>
          <div class="hero__video-overlay" id="hero-video-overlay">
            <div class="hero__video-play-btn">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#fff"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
            <span class="hero__video-cta">{hero.video_cta}</span>
          </div>
          <div class="hero__video-muted-badge" id="hero-muted-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
            <span>Sound off</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true" style="animation: fade-in 1.2s var(--ease) 1s both;">
      <span>Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══ INTRO ═══ -->
  <section class="section intro">
    <div class="container">
      <div class="intro__layout">
        <div class="intro__text reveal">
          <span class="section-label">{intro.label}</span>
          <h2 class="text-balance" set:html={intro.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
          <p class="mb-md">{intro.body}</p>
          <a href="#collective" class="btn btn--teal">{intro.cta}</a>
        </div>
        <div class="intro__cards">
          {intro.features.map((f: any, i: number) => (
            <div class={`intro__card reveal reveal-delay-${i + 1}`}>
              <span class="intro__card-icon">{f.icon}</span>
              <div>
                <h4>{f.title}</h4>
                <p>{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EVENTS ═══ -->
  <section class="section section--dark events" id="events">
    <div class="divider" style="position:absolute;top:0;left:0;right:0;height:4px;" aria-hidden="true"></div>
    <div class="container">
      <div class="events__head reveal">
        <span class="section-label" style="color: var(--teal);">{eventsData.label}</span>
        <h2 set:html={eventsData.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
        <p style="color: rgba(255,255,255,0.55); max-width: 50ch;">{eventsData.subtitle}</p>
      </div>
      <div class={`events__grid events__grid--${Math.min(eventsData.cards.length, 3)}`}>
        {eventsData.cards.map((card: any, i: number) => (
          <a href={card.url || '#'} target={card.url ? '_blank' : undefined} rel={card.url ? 'noopener' : undefined} class={`events__card ${card.featured ? 'events__card--featured' : ''} reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="events__card-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
            <span class="badge badge--coral">{card.type}</span>
            <h3>{card.name}</h3>
            <p>{card.desc}</p>
            <span class="events__card-tag">{card.status}</span>
            {card.url && (
              <span class="events__card-cta" aria-hidden="true">
                RSVP Now
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BRAND MARQUEE ═══ -->
  <section class="section brands">
    <div class="container text-center mb-lg reveal">
      <h2 set:html={brandsData.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
    </div>
    <div class="marquee-wrapper">
      <div class="marquee-track">
        {[...brandsData.names, ...brandsData.names].map((brand: string) => (
          <span class="brands__pill">{brand}</span>
        ))}
      </div>
    </div>
    <div class="marquee-wrapper" style="margin-top: 0.75rem;">
      <div class="marquee-track" style="animation-direction: reverse; animation-duration: 35s;">
        {[...brandsData.names, ...brandsData.names].reverse().map((brand: string) => (
          <span class="brands__pill brands__pill--alt">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ PHOTO MASONRY ═══ -->
  <section class="section masonry-section">
    <div class="container text-center mb-lg reveal">
      <span class="section-label" style="justify-content: center;">{gallery.label}</span>
      <h2 set:html={gallery.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
    </div>
    <div class="container">
      <div class="masonry reveal">
        {gallery.photos.map((photo: string) => (
          <img
            src={`${import.meta.env.BASE_URL}photos/${photo}.webp`}
            alt="CX Mixer event"
            loading="lazy"
            class={photo === gallery.featured ? 'masonry__featured' : ''}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ COLLECTIVE ═══ -->
  <section class="section community" id="collective">
    <div class="container">
      <div class="community__layout">
        <div class="community__visual reveal">
          <div class="community__blob" aria-hidden="true"></div>
          {collective.notifications.map((note: string, i: number) => {
            const count = collective.notifications.length;
            const topPct = Math.round((i / (count - 1)) * 70 + 8);
            const isRight = i % 2 === 1;
            // First and last items inset more
            const isEdge = i === 0 || i === count - 1;
            const leftPos = isEdge ? '15%' : '5%';
            const rightPos = isEdge ? '10%' : '0%';
            const style = `top:${topPct}%;${isRight ? `right:${rightPos}` : `left:${leftPos}`};animation-delay:${i * 1.2}s;`;
            return (
              <div class="community__float" style={style}>
                {note}
              </div>
            );
          })}
        </div>
        <div class="community__text reveal reveal-delay-1">
          <span class="section-label">{collective.label}</span>
          <h2 class="text-balance" set:html={collective.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
          <p class="mb-md">{collective.body}</p>
          <p class="community__quote mb-lg">{collective.quote}</p>
          <div class="community__values">
            {collective.values.map((v: any) => (
              <div class="community__value">
                <span>{v.icon}</span>
                <span>{v.text}</span>
              </div>
            ))}
          </div>
          <div class="community__cta">
            <a href="#contact" class="btn btn--primary">{collective.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PODCAST ═══ -->
  <section class="section section--dark podcast" id="podcast">
    <div class="divider" style="position:absolute;top:0;left:0;right:0;height:4px;" aria-hidden="true"></div>
    <div class="container">
      <div class="podcast__head reveal">
        <span class="section-label" style="color: var(--teal);">{podcast.label}</span>
        <h2 set:html={podcast.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
        <p style="color: rgba(255,255,255,0.55); max-width: 50ch;">{podcast.subtitle}</p>
      </div>

      <!-- Season 1 -->
      <h3 class="podcast__season reveal" style="color: var(--cyan); margin-bottom: var(--sp-md);">Season 1</h3>
      <div class="podcast__grid reveal">
        {season1.map((ep) => (
          <div class="yt-card">
            <a href={`https://youtu.be/${ep.id}`} target="_blank" rel="noopener" class="yt-card__thumb">
              <img src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`} alt={ep.title} loading="lazy" />
              <div class="yt-card__play">
                <svg width="48" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
              </div>
            </a>
            <div class="yt-card__info">
              <span class="badge badge--dark">{ep.ep}</span>
              <h4>{ep.title}</h4>
              <p>{ep.guests}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Season 2 + Bonus -->
      <h3 class="podcast__season reveal" style="color: var(--cyan); margin-top: var(--sp-xl); margin-bottom: var(--sp-md);">Season 2</h3>
      <div class="podcast__grid reveal">
        {season2.map((ep) => (
          <div class="yt-card">
            <a href={`https://youtu.be/${ep.id}`} target="_blank" rel="noopener" class="yt-card__thumb">
              <img src={`https://img.youtube.com/vi/${ep.id}/maxresdefault.jpg`} alt={ep.title} loading="lazy" />
              <div class="yt-card__play">
                <svg width="48" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
              </div>
            </a>
            <div class="yt-card__info">
              <span class="badge badge--dark">{ep.ep}</span>
              <h4>{ep.title}</h4>
              <p>{ep.guests}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center reveal" style="margin-top: var(--sp-xl);">
        <div class="podcast__ctas">
          <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="btn btn--white">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
            Spotify
          </a>
          <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="btn btn--ghost">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
            YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="section quotes">
    <div class="container">
      <div class="quotes__grid reveal">
        {quotes.map((q: any) => (
          <a href={q.url} target="_blank" rel="noopener" class={`quotes__card ${q.accent ? 'quotes__card--accent' : ''}`}>
            <div class="quotes__mark" aria-hidden="true">&ldquo;</div>
            <p>{q.text}</p>
            <div class="quotes__author">
              <img src={`${import.meta.env.BASE_URL}quotes/${q.photo}.webp`} alt={q.name} class="quotes__avatar" />
              <cite>{q.name}<span>{q.role}</span></cite>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SPONSORS ═══ -->
  <section class="section section--coral sponsor-tease" id="sponsors">
    <div class="sponsor-tease__deco" aria-hidden="true">&#x2726;</div>
    <div class="container">
      <div class="sponsor__layout reveal">
        <div class="sponsor__text">
          <h2 class="mb-md" set:html={sponsors.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
          <p style="opacity: 0.85; margin-bottom: var(--sp-lg);">{sponsors.body}</p>
          <a href="#contact" class="btn btn--white">{sponsors.cta}</a>
        </div>
        <div class="sponsor__video">
          <iframe src={links.sponsor_video} title="CX Mixer Sponsor Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="sponsor__video-el"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT ═══ -->
  <section class="section about-section" id="about">
    <div class="container">
      <div class="about__layout">
        <div class="reveal">
          <span class="section-label">{about.label}</span>
          <h2 class="text-balance" set:html={about.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
          <p class="mb-md">{about.body_1}</p>
          <p>{about.body_2}</p>
        </div>
        <div class="about__people">
          {about.team.map((person: any, i: number) => (
            <a href={person.linkedin} target="_blank" rel="noopener" class={`about__card reveal reveal-delay-${i + 1}`}>
              <div class="about__avatar">
                <img src={`${import.meta.env.BASE_URL}photos/${person.photo}.webp`} alt={person.name} class="about__headshot" />
              </div>
              <h3>{person.name}</h3>
              <p class="about__role">{person.role}</p>
              <p class="about__bio">{person.bio}</p>
              <span class="about__linkedin">View on LinkedIn</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section class="section section--dark contact-section" id="contact">
    <div class="divider" style="position:absolute;top:0;left:0;right:0;height:4px;" aria-hidden="true"></div>
    <div class="container">
      <div class="contact__layout">
        <div class="contact__info reveal">
          <span class="section-label" style="color: var(--teal);">{contact.label}</span>
          <h2 set:html={contact.title.replace(/\*([^*]+)\*/g, '<em class="serif">$1</em>')} />
          <p style="color: rgba(255,255,255,0.55); margin-bottom: var(--sp-lg);">
            {contact.subtitle}
          </p>
          <div class="contact__links">
            <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="contact__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
              YouTube
            </a>
            <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="contact__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
              Spotify
            </a>
            <a href="https://www.linkedin.com/company/the-cx-mixer/" target="_blank" rel="noopener" class="contact__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.4 20.5h-3.6v-5.6c0-1.3 0-3-1.9-3s-2.1 1.4-2.1 2.9v5.7H9.2V9h3.4v1.6h.1c.5-.9 1.6-1.9 3.4-1.9 3.6 0 4.3 2.4 4.3 5.5v6.3zM5.3 7.4a2.1 2.1 0 1 1 0-4.2 2.1 2.1 0 0 1 0 4.2zM7.1 20.5H3.5V9h3.6v11.5zM22.2 0H1.8C.8 0 0 .8 0 1.7v20.6c0 .9.8 1.7 1.8 1.7h20.4c1 0 1.8-.8 1.8-1.7V1.7c0-.9-.8-1.7-1.8-1.7z"/></svg>
              LinkedIn
            </a>
            <a href="https://www.instagram.com/cxmixer" target="_blank" rel="noopener" class="contact__link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zM12 0C8.7 0 8.3 0 7.1.1 5.8.1 4.9.3 4.1.6c-.8.3-1.5.7-2.2 1.4C1.3 2.6.9 3.3.6 4.1.3 4.9.1 5.8.1 7.1 0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.2 2.2.5 2.9.3.8.7 1.5 1.4 2.2.7.7 1.4 1.1 2.2 1.4.8.3 1.6.5 2.9.5C8.3 24 8.7 24 12 24s3.7 0 4.9-.1c1.3-.1 2.2-.2 2.9-.5.8-.3 1.5-.7 2.2-1.4.7-.7 1.1-1.4 1.4-2.2.3-.8.5-1.6.5-2.9.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.2-2.2-.5-2.9-.3-.8-.7-1.5-1.4-2.2-.7-.7-1.4-1.1-2.2-1.4C19.1.3 18.2.1 16.9.1 15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4A6.2 6.2 0 0 0 12 5.8zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm7.8-10.4a1.4 1.4 0 1 0-2.8 0 1.4 1.4 0 0 0 2.8 0z"/></svg>
              Instagram
            </a>
          </div>
        </div>
        <div class="contact__form-wrap reveal reveal-delay-1">
          <div class="contact__success" id="contact-success" hidden>
            <span class="contact__success-icon" aria-hidden="true">✓</span>
            <div>
              <strong>Thanks — your note's on its way.</strong>
              <p>We'll get back to you soon.</p>
            </div>
          </div>
          <form class="contact__form" name="contact" method="POST" action={contact.form_action} id="contact-form">
            <!-- Honeypot field — hidden from humans, traps bots -->
            <input type="text" name="_honey" style="display:none !important;" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_subject" value="New CX Mixer inquiry" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://cxmixer.com/?sent=1" />
            <div class="contact__form-row">
              <div class="contact__field">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required placeholder="Your name" />
              </div>
              <div class="contact__field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="you@company.com" />
              </div>
            </div>
            <div class="contact__form-row">
              <div class="contact__field">
                <label for="company">Company</label>
                <input type="text" id="company" name="company" placeholder="Your company" />
              </div>
              <div class="contact__field">
                <label for="type">Inquiry Type</label>
                <select id="type" name="inquiry_type" required>
                  <option value="" disabled selected>Pick the lane that fits</option>
                  {contact.inquiry_types.map((t: string) => (
                    <option value={t}>{t}</option>
                  ))}
                </select>
              </div>
            </div>
            <div class="contact__field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="4" required placeholder="What's on your mind?"></textarea>
            </div>
            <button type="submit" class="btn btn--primary">Send Your Note</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox modal -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox__close" aria-label="Close">&times;</button>
    <img class="lightbox__img" id="lightbox-img" alt="" />
  </div>

</Base>

<style>
  /* ═══ LIGHTBOX ═══ */
  .lightbox {
    position: fixed; inset: 0; z-index: 99999;
    background: rgba(10, 6, 20, 0.92); backdrop-filter: blur(20px);
    display: flex; align-items: center; justify-content: center;
    padding: var(--sp-lg);
    opacity: 0; pointer-events: none;
    transition: opacity var(--med) var(--ease);
  }
  .lightbox.open { opacity: 1; pointer-events: auto; }
  .lightbox__img { max-width: 90vw; max-height: 85vh; border-radius: var(--r-lg); object-fit: contain; transform: scale(0.9); transition: transform var(--med) var(--ease-bounce); }
  .lightbox.open .lightbox__img { transform: scale(1); }
  .lightbox__close { position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none; color: #fff; font-size: 2.5rem; cursor: pointer; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background var(--fast); }
  .lightbox__close:hover { background: rgba(255,255,255,0.1); }
  /* ═══ HERO ═══ */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 68px;
    overflow: hidden;
    background: linear-gradient(135deg, #1A0A2E 0%, #2D0845 50%, #1A0A2E 100%);
  }

  .hero__bg { position: absolute; inset: 0; overflow: hidden; }

  .hero__orb { position: absolute; border-radius: 50%; filter: blur(100px); will-change: transform; }
  .hero__orb--1 { width: 700px; height: 700px; background: radial-gradient(circle, rgba(233,30,140,0.35), transparent 70%); top: -250px; right: -150px; animation: float 20s ease-in-out infinite; }
  .hero__orb--2 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(83,198,214,0.25), transparent 70%); bottom: -150px; left: -100px; animation: float 25s ease-in-out infinite reverse; }
  .hero__orb--3 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(139,49,199,0.25), transparent 70%); top: 45%; left: 55%; animation: float 18s ease-in-out infinite 3s; }

  .hero__grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px); background-size: 80px 80px; mask-image: radial-gradient(ellipse at 30% 50%, black 30%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse at 30% 50%, black 30%, transparent 75%); }

  .hero__deco { position: absolute; pointer-events: none; }
  .hero__deco--star { font-size: 3rem; color: var(--magenta); opacity: 0.35; top: 18%; right: 12%; animation: pulse-glow 4s ease-in-out infinite; }
  .hero__deco--cross { font-family: var(--font-display); font-size: 4rem; font-weight: 900; color: var(--neon); opacity: 0.15; bottom: 25%; right: 22%; animation: spin-slow 40s linear infinite reverse; }
  .hero__deco--ring { width: 180px; height: 180px; border: 3px solid var(--cyan); border-radius: 50%; opacity: 0.12; top: 30%; right: 5%; animation: spin-slow 50s linear infinite; }
  .hero__deco--logo { width: 320px; height: auto; opacity: 0.06; top: 50%; right: -40px; transform: translateY(-50%) rotate(-8deg); animation: float 15s ease-in-out infinite; filter: blur(1px); }

  .hero__layout { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr auto; gap: var(--sp-xl); align-items: center; padding-top: var(--sp-3xl); padding-bottom: var(--sp-3xl); }
  .hero__content { max-width: 700px; }

  .hero__video { flex-shrink: 0; }
  .hero__video-wrap { position: relative; cursor: pointer; border-radius: var(--r-xl); overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 40px rgba(233,30,140,0.15); border: 2px solid rgba(255,255,255,0.1); width: 280px; transition: all var(--med) var(--ease-bounce); }
  .hero__video-wrap:hover { transform: scale(1.03); box-shadow: 0 24px 70px rgba(0,0,0,0.5), 0 0 50px rgba(233,30,140,0.25); }
  .hero__video-wrap.playing { cursor: default; }
  .hero__video-el { width: 100%; height: auto; display: block; }

  .hero__video-overlay { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 0.5rem; padding-bottom: 1.5rem; background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.5) 100%); transition: opacity var(--med) var(--ease); }
  .hero__video-wrap.playing .hero__video-overlay { opacity: 0; pointer-events: none; }
  .hero__video-play-btn { width: 56px; height: 56px; border-radius: 50%; background: var(--magenta); display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 30px rgba(233,30,140,0.5); animation: pulse-glow 2s ease-in-out infinite; transition: transform var(--med) var(--ease-bounce); }
  .hero__video-play-btn svg { margin-left: 3px; }
  .hero__video-wrap:hover .hero__video-play-btn { transform: scale(1.1); }
  .hero__video-cta { font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 0.1em; text-shadow: 0 2px 8px rgba(0,0,0,0.5); }

  .hero__video-muted-badge { position: absolute; top: 0.75rem; right: 0.75rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); border-radius: var(--r-pill); padding: 0.3rem 0.6rem; display: flex; align-items: center; gap: 0.35rem; color: rgba(255,255,255,0.7); font-family: var(--font-display); font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; animation: pulse-glow 3s ease-in-out infinite; transition: opacity var(--fast), visibility var(--fast); }
  .hero__video-wrap.playing .hero__video-muted-badge { opacity: 0 !important; visibility: hidden; pointer-events: none; animation: none; }

  @media (max-width: 960px) {
    .hero__layout { grid-template-columns: 1fr; }
    .hero__video { justify-self: center; }
    .hero__video-wrap { width: 240px; }
  }
  .hero__eyebrow { margin-bottom: var(--sp-md); }
  .hero__title { color: #fff; margin-bottom: var(--sp-md); line-height: 1.0; }
  .hero__em { display: block; background: linear-gradient(135deg, var(--magenta) 0%, var(--neon) 50%, var(--cyan) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; padding-top: 0.1em; padding-bottom: 0.15em; line-height: 1.2; }
  .hero__em .serif { font-size: 1.1em; }
  .hero__sub { color: rgba(255,255,255,0.55); font-size: 1.1rem; line-height: 1.75; margin-bottom: var(--sp-lg); max-width: 52ch; }
  .hero__actions { display: flex; gap: var(--sp-sm); flex-wrap: wrap; margin-bottom: var(--sp-xl); }
  .hero__listen { display: flex; align-items: center; gap: var(--sp-sm); }
  .hero__listen-label { color: rgba(255,255,255,0.3); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; font-family: var(--font-display); }
  .hero__listen-icon { color: rgba(255,255,255,0.3); transition: all var(--fast) var(--ease-bounce); display: flex; }
  .hero__listen-icon:hover { color: var(--coral); transform: scale(1.2) translateY(-2px); }

  .hero__scroll { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.25); font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; }
  .hero__scroll-line { width: 1.5px; height: 40px; background: linear-gradient(to bottom, var(--magenta), transparent); animation: pulse-glow 2s ease-in-out infinite; }

  /* ═══ INTRO ═══ */
  .intro__layout { display: grid; grid-template-columns: 1.1fr 1fr; gap: var(--sp-2xl); align-items: start; }
  .intro__cards { display: flex; flex-direction: column; gap: 0.75rem; }
  .intro__card { display: flex; align-items: flex-start; gap: var(--sp-md); padding: var(--sp-md) var(--sp-lg); background: var(--surface); border-radius: var(--r-lg); border: 2px solid var(--border); transition: all var(--med) var(--ease); cursor: default; }
  .intro__card:hover { border-color: var(--magenta); transform: translateX(8px) rotate(-0.5deg); box-shadow: -8px 8px 0 var(--magenta), 0 0 30px rgba(233,30,140,0.15); }
  .intro__card-icon { font-size: 1.8rem; flex-shrink: 0; margin-top: 2px; }
  .intro__card h4 { margin-bottom: 0.1rem; font-size: 1.05rem; }
  .intro__card p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.5; }

  @media (max-width: 768px) { .intro__layout { grid-template-columns: 1fr; gap: var(--sp-xl); } }

  /* ═══ EVENTS ═══ */
  .events__head { margin-bottom: var(--sp-xl); }
  .events__head .section-label::before { background: var(--teal); }
  .events__grid { display: grid; gap: var(--sp-md); }
  .events__grid--1 { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
  .events__grid--2 { grid-template-columns: repeat(2, 1fr); max-width: 800px; margin: 0 auto; }
  .events__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .events__card { display: block; text-decoration: none; color: inherit; background: rgba(255,255,255,0.03); border: 2px solid rgba(255,255,255,0.08); border-radius: var(--r-xl); padding: var(--sp-lg); position: relative; overflow: hidden; transition: all var(--med) var(--ease); }
  .events__card:hover { border-color: var(--magenta); transform: translateY(-8px) rotate(-1deg); box-shadow: 0 20px 50px rgba(233,30,140,0.2), 0 0 60px rgba(233,30,140,0.08); }
  .events__card--featured { border-color: var(--coral); background: rgba(255,94,53,0.06); }
  .events__card-num { font-family: var(--font-display); font-weight: 900; font-size: 5rem; color: rgba(255,255,255,0.04); position: absolute; top: -0.5rem; right: 1rem; line-height: 1; pointer-events: none; }
  .events__card h3 { color: #fff; font-size: 1.3rem; margin: 0.6rem 0 0.4rem; }
  .events__card p { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-bottom: var(--sp-md); }
  .events__card-tag { font-family: var(--font-display); font-weight: 700; font-size: 0.75rem; color: var(--teal); text-transform: uppercase; letter-spacing: 0.08em; display: block; }
  .events__card-cta { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: var(--sp-md); padding: 0.5rem 1rem; background: var(--magenta); color: #fff; border-radius: var(--r-pill); font-family: var(--font-display); font-weight: 700; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; transition: all var(--fast) var(--ease); }
  .events__card-cta svg { transition: transform var(--fast) var(--ease); }
  .events__card:hover .events__card-cta { background: #fff; color: var(--magenta); }
  .events__card:hover .events__card-cta svg { transform: translateX(3px); }
  .events__card--featured .events__card-cta { background: var(--coral); }
  .events__card--featured:hover .events__card-cta { background: #fff; color: var(--coral); }

  @media (max-width: 768px) { .events__grid { grid-template-columns: 1fr; } }

  /* ═══ BRANDS ═══ */
  .brands { padding-bottom: var(--sp-xl); overflow: hidden; }
  .brands__pill { font-family: var(--font-display); font-weight: 700; font-size: 0.95rem; color: var(--ink); padding: 0.55rem 1.4rem; margin: 0 0.35rem; background: var(--surface); border-radius: var(--r-pill); border: 2px solid var(--border); white-space: nowrap; transition: all var(--fast) var(--ease); letter-spacing: -0.01em; }
  .brands__pill:hover { border-color: var(--coral); color: var(--coral); transform: scale(1.05); }
  .brands__pill--alt { background: var(--ink); color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.1); }
  .brands__pill--alt:hover { border-color: var(--teal); color: var(--teal); }

  /* ═══ MASONRY (CSS columns) ═══ */
  .masonry-section { overflow: hidden; }

  .masonry {
    columns: 5;
    column-gap: 0.6rem;
  }

  .masonry img {
    width: 100%;
    display: block;
    border-radius: var(--r-md);
    margin-bottom: 0.6rem;
    break-inside: avoid;
    transition: all var(--med) var(--ease);
    cursor: pointer;
  }

  .masonry img:hover {
    transform: scale(1.04) rotate(-0.5deg);
    box-shadow: 0 12px 40px rgba(233, 30, 140, 0.25);
    z-index: 1;
    position: relative;
  }

  .masonry__featured {
    border: 3px solid var(--magenta) !important;
    box-shadow: 0 0 30px rgba(233, 30, 140, 0.25) !important;
  }

  .masonry__featured:hover {
    box-shadow: 0 0 50px rgba(233, 30, 140, 0.4), 0 12px 40px rgba(233, 30, 140, 0.25) !important;
  }

  @media (max-width: 1024px) {
    .masonry { columns: 4; }
  }

  @media (max-width: 768px) {
    .masonry { columns: 3; }
  }

  @media (max-width: 480px) {
    .masonry { columns: 2; column-gap: 0.4rem; }
    .masonry img { margin-bottom: 0.4rem; border-radius: var(--r-sm); }
  }

  /* ═══ COMMUNITY ═══ */
  .community__layout { display: grid; grid-template-columns: 1fr 1.1fr; gap: var(--sp-2xl); align-items: center; }
  .community__visual { position: relative; height: 440px; }
  .community__blob { position: absolute; width: 260px; height: 260px; border-radius: 50%; background: linear-gradient(135deg, rgba(0,212,170,0.15), rgba(124,58,237,0.1)); filter: blur(60px); top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .community__float { position: absolute; background: var(--surface); border-radius: var(--r-lg); padding: 0.75rem 1.1rem; display: flex; align-items: center; gap: 0.6rem; font-family: var(--font-display); font-weight: 600; font-size: 0.8rem; box-shadow: 0 12px 40px rgba(10,15,28,0.12); border: 2px solid var(--border); animation: float 6s ease-in-out infinite; white-space: nowrap; }
  .community__quote { font-family: var(--font-serif); font-style: italic; font-size: 1.1rem; color: var(--coral); border-left: 3px solid var(--coral); padding-left: var(--sp-md); }
  .community__values { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: var(--sp-lg); }
  .community__value { display: flex; align-items: center; gap: 0.5rem; background: rgba(233,30,140,0.06); border: 1px solid rgba(233,30,140,0.15); border-radius: var(--r-pill); padding: 0.45rem 1rem; font-size: 0.85rem; font-weight: 500; }
  .community__cta { margin-top: var(--sp-lg); }

  @media (max-width: 768px) { .community__layout { grid-template-columns: 1fr; } .community__visual { height: 260px; } .community__cta { display: flex; justify-content: center; } .community__cta .btn { width: 100%; max-width: 320px; } }

  /* ═══ PODCAST ═══ */
  .podcast__head { margin-bottom: var(--sp-xl); }
  .podcast__head .section-label::before { background: var(--teal); }
  .podcast__season { font-family: var(--font-display); font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; }
  .podcast__ctas { display: flex; gap: var(--sp-sm); justify-content: center; flex-wrap: wrap; }

  /* YouTube thumbnail cards */
  .podcast__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-md); }

  .yt-card { border-radius: var(--r-lg); overflow: hidden; background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.06); transition: all var(--med) var(--ease); }
  .yt-card:hover { transform: translateY(-6px) rotate(-0.5deg); border-color: var(--magenta); box-shadow: 0 20px 50px rgba(233,30,140,0.15); }

  .yt-card__thumb { position: relative; display: block; aspect-ratio: 16/9; overflow: hidden; }
  .yt-card__thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--med) var(--ease); }
  .yt-card:hover .yt-card__thumb img { transform: scale(1.05); }

  .yt-card__play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.2); opacity: 0; transition: opacity var(--fast) var(--ease); }
  .yt-card:hover .yt-card__play { opacity: 1; }
  .yt-card__play svg { filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4)); transition: transform var(--med) var(--ease-bounce); }
  .yt-card:hover .yt-card__play svg { transform: scale(1.15); }

  .yt-card__info { padding: var(--sp-md); }
  .yt-card__info .badge { margin-bottom: 0.5rem; }
  .yt-card__info h4 { color: #fff; font-size: 0.95rem; line-height: 1.3; margin-bottom: 0.3rem; }
  .yt-card__info p { color: rgba(255,255,255,0.4); font-size: 0.8rem; }

  @media (max-width: 768px) { .podcast__grid { grid-template-columns: 1fr; } }
  @media (min-width: 769px) and (max-width: 1024px) { .podcast__grid { grid-template-columns: repeat(2, 1fr); } }

