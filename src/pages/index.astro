  .community__quote { font-family: var(--font-serif); font-style: italic; font-size: 1.1rem; color: var(--coral); border-left: 3px solid var(--coral); padding-left: var(--sp-md); }
  .community__values { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: var(--sp-lg); }
  .community__value { display: flex; align-items: center; gap: 0.5rem; background: rgba(233,30,140,0.06); border: 1px solid rgba(233,30,140,0.15); border-radius: var(--r-pill); padding: 0.45rem 1rem; font-size: 0.85rem; font-weight: 500; }

  @media (max-width: 768px) { .community__layout { grid-template-columns: 1fr; } .community__visual { height: 260px; } }

  /* ═══ PODCAST ═══ */
  .podcast__head { margin-bottom: var(--sp-xl); }
  .podcast__head .section-label::before { background: var(--teal); }
  .podcast__season { font-family: var(--font-display); font-size: 1.1rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; }
  .podcast__ctas { display: flex; gap: var(--sp-sm); justify-content: center; flex-wrap: wrap; }

  /* YouTube thumbnail cards */
  .podcast__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-md); }

  .yt-card { border-radius: var(--r-lg); overflow: hidden; background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.06); transition: all var(--med) var(--ease); }
  .yt-card:hover { transform: translateY(-6px) rotate(-0.5deg); border-color: var(--magenta); box-shadow: 0 20px 50px rgba(233,30,140,0.15); }

  .yt-card__thumb { position: relative; display: block; aspect-ratio: 16/9; overflow: hidden; }
  .yt-card__thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--med) var(--ease); }
  .yt-card:hover .yt-card__thumb img { transform: scale(1.05); }

  .yt-card__play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.2); opacity: 0; transition: opacity var(--fast) var(--ease); }
  .yt-card:hover .yt-card__play { opacity: 1; }
