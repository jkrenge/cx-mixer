---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const episodes = [
  { title: 'How 8 CX Leaders Are Making AI Work — Right Now', guests: 'Glossier, Dr. Squatch, Caraway, BaubleBar, 32 Degrees, True Classic, Wyze', date: 'Dec 23, 2025', duration: '1 hr 32 min', tag: 'Bonus', desc: 'Eight CX leaders explore the fast-changing world of AI-powered customer experience — from personality-driven chatbots to fraud prevention.' },
  { title: '0 to 100: Building CX From Day One', guests: 'Breanna Moreno & Dan Kaparski', date: 'Dec 11, 2025', duration: '56 min', tag: 'S2', desc: 'A dynamic discussion on building customer experience from day one at a celebrity-backed fashion brand.' },
  { title: 'Quiet Luxury, Human CX', guests: 'Lisa (Everlane) & Chad (Vuori)', date: 'Nov 20, 2025', duration: '1 hr 1 min', tag: 'S2', desc: 'How premium brands balance quality, approachability, and sustainability while adapting their CX strategies.' },
  { title: 'The Modern Man\'s Journey: From Rugged to Refined', guests: 'Katy (Suit Shop) & Nichelle (Taylor Stitch)', date: 'Nov 6, 2025', duration: '56 min', tag: 'S2', desc: 'The shift in male consumer behavior and the growing importance of personalization and emotional connection.' },
  { title: 'The Fine Print: Fighting Fraud Without Losing Customers', guests: 'Michael (Fanatics Live) & Taylor (Nathan James)', date: 'Oct 23, 2025', duration: '1 hr 6 min', tag: 'S2', desc: 'Combating fraud in e-commerce without alienating customers — from return abuse to warranty scams.' },
  { title: 'From Cart to Closet to Cup Holder', guests: 'Katie (Simple Modern) & Jennifer (32 Degrees)', date: 'Oct 9, 2025', duration: '54 min', tag: 'S1', desc: 'CX strategies for modern essentials brands navigating growth and customer expectations.' },
  { title: 'Gold Chains and Soap Bars', guests: 'Caela (Jaxxon) & Tess (Dr. Squatch)', date: 'Jul 24, 2025', duration: '1 hr 2 min', tag: 'S1', desc: 'Female CX bosses revolutionizing men\'s brands and redefining the customer experience playbook.' },
  { title: 'Everywhere All at Once: Mastering CX Across Channels', guests: 'Logan (Wyze) & Jennifer (Olly)', date: 'Jul 10, 2025', duration: '1 hr', tag: 'S1', desc: 'How to deliver consistent customer experience across every touchpoint without losing your mind.' },
  { title: 'From Cart to Community', guests: 'Cati (Glossier) & Maritza (BaubleBar)', date: 'Jun 26, 2025', duration: '1 hr', tag: 'S1', desc: 'Building CX that connects customers to something bigger than a transaction.' },
  { title: 'The Impact A Small CX Team Can Have', guests: 'Nancy (Caraway) & Daniel (Carpe)', date: 'Jun 12, 2025', duration: '54 min', tag: 'S1', desc: 'How lean CX teams punch above their weight and drive outsized impact for growing brands.' },
  { title: 'The Customer ISN\'T Always Right', guests: 'Jordan (True Classic) & Max (Tommy John)', date: 'May 27, 2025', duration: '43 min', tag: 'S1', desc: 'A candid conversation about setting boundaries, managing expectations, and still delivering world-class service.' },
];
---

<Base title="CX Mixer Podcast | Conversations for E-commerce & CX Leaders" description="Listen to practical, honest conversations with e-commerce operators, customer experience leaders, and brand builders on the CX Mixer podcast.">

  <!-- HERO -->
  <section class="page-hero section--dark">
    <div class="page-hero-bg" aria-hidden="true">
      <div class="hero-shape hero-shape--1"></div>
      <div class="hero-shape hero-shape--2"></div>
    </div>
    <div class="container page-hero-content">
      <span class="badge badge--coral reveal">Podcast</span>
      <h1 class="reveal reveal-delay-1">Conversations worth<br/>pulling your headphones out for</h1>
      <p class="page-hero-subtitle reveal reveal-delay-2">
        The CX Mixer podcast features honest conversations with the people building, fixing, and rethinking the e-commerce customer experience.
      </p>
      <div class="hero-ctas reveal reveal-delay-3">
        <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="btn btn--primary">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
          Listen on Spotify
        </a>
        <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="btn btn--outline-white">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          Watch on YouTube
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT YOU'LL HEAR -->
  <section class="section">
    <div class="container" style="max-width: 750px;">
      <div class="reveal text-center">
        <span class="section-label" style="justify-content: center;">The Show</span>
        <h2 class="mb-md text-balance">What you'll hear</h2>
        <p>This isn't a buzzword parade. CX Mixer conversations are practical, funny, and grounded in what brand teams are actually dealing with right now. Think CX, growth, post-purchase, retention, tech, operations, and all the stuff that happens after the panel ends.</p>
      </div>
    </div>
  </section>

  <!-- EPISODES -->
  <section class="section" style="background: #fff;" id="episodes">
    <div class="container">
      <div class="reveal mb-xl">
        <span class="section-label">All Episodes</span>
        <h2>Every conversation so far</h2>
      </div>
      <div class="episodes-list">
        {episodes.map((ep, i) => (
          <article class={`episode-row reveal ${i < 4 ? `reveal-delay-${i + 1}` : ''}`}>
            <div class="episode-number">
              <span class="badge">{ep.tag}</span>
            </div>
            <div class="episode-info">
              <h3>{ep.title}</h3>
              <p class="episode-guests">{ep.guests}</p>
              <p class="episode-desc">{ep.desc}</p>
            </div>
            <div class="episode-meta">
              <span class="episode-date">{ep.date}</span>
              <span class="episode-duration">{ep.duration}</span>
            </div>
            <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="episode-play" aria-label={`Listen to ${ep.title}`}>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED BRANDS -->
  <section class="section">
    <div class="container text-center">
      <div class="reveal mb-lg">
        <span class="section-label" style="justify-content: center;">Who's Been On</span>
        <h2>Brands on the mic</h2>
        <p style="max-width: 55ch; margin: 0 auto;">Operators, brand leaders, and industry builders with something useful to say and the personality to make it worth listening to.</p>
      </div>
      <div class="brand-tags reveal">
        {['Glossier', 'True Classic', 'Everlane', 'Vuori', 'Tommy John', 'Dr. Squatch', 'Caraway', 'Carpe', 'BaubleBar', '32 Degrees', 'Wyze', 'Jaxxon', 'Olly', 'Simple Modern', 'Suit Shop', 'Taylor Stitch', 'Fanatics Live', 'Nathan James'].map((brand) => (
          <span class="brand-tag">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- GUEST INQUIRY -->
  <section class="section section--dark">
    <div class="container">
      <div class="guest-grid">
        <div class="reveal">
          <span class="section-label" style="color: var(--coral);">Be a Guest</span>
          <h2>Got something worth talking about?</h2>
          <p style="color: rgba(255,255,255,0.7);">We're always looking for smart, thoughtful voices from the e-commerce world. If you've got real experience, real opinions, and a good story — let's talk.</p>
          <a href={`${base}contact/`} class="btn btn--primary" style="margin-top: var(--sp-md);">Be Our Next Guest</a>
        </div>
        <div class="reveal reveal-delay-1">
          <div class="guest-stats">
            <div class="stat-item">
              <span class="stat-number">11</span>
              <span class="stat-label">Episodes</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">18+</span>
              <span class="stat-label">Brands Featured</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">5.0</span>
              <span class="stat-label">Star Rating</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LISTEN CTA -->
  <section class="section">
    <div class="container text-center">
      <div class="reveal" style="max-width: 600px; margin: 0 auto;">
        <h2 class="mb-md text-balance">Follow the show</h2>
        <p class="mb-lg">New episodes drop twice a month. Subscribe so you never miss a conversation.</p>
        <div class="listen-links">
          <a href="https://open.spotify.com/show/4a2lEUxl4dGm4CqdNm3HvZ" target="_blank" rel="noopener" class="btn btn--teal">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.5 17.3c-.2.3-.6.4-1 .2-2.7-1.7-6.1-2-10.1-1.1-.4.1-.8-.1-.9-.5-.1-.4.1-.8.5-.9 4.4-1 8.1-.6 11.2 1.3.3.2.4.7.3 1zm1.5-3.3c-.3.4-.8.5-1.2.3-3.1-1.9-7.8-2.5-11.5-1.3-.5.1-1-.1-1.1-.6-.1-.5.1-1 .6-1.1 4.2-1.3 9.4-.7 13 1.5.3.2.5.7.2 1.2zm.1-3.4c-3.7-2.2-9.9-2.4-13.4-1.3-.5.2-1.1-.1-1.3-.7-.2-.5.1-1.1.7-1.3 4.1-1.2 10.8-1 15 1.5.5.3.7.9.4 1.4-.3.5-.9.6-1.4.4z"/></svg>
            Spotify
          </a>
          <a href="https://www.youtube.com/@CXMixer" target="_blank" rel="noopener" class="btn btn--secondary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.9 31.9 0 0 0 0 12a31.9 31.9 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
            YouTube
          </a>
          <a href="https://podcasts.apple.com/us/podcast/the-cx-mixer" target="_blank" rel="noopener" class="btn btn--secondary">
            Apple Podcasts
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    position: relative;
    padding: calc(72px + var(--sp-3xl)) 0 var(--sp-3xl);
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .hero-shape--1 {
    width: 500px;
    height: 500px;
    background: rgba(249, 115, 58, 0.18);
    top: -150px;
    left: -100px;
  }

  .hero-shape--2 {
    width: 400px;
    height: 400px;
    background: rgba(31, 166, 160, 0.12);
    bottom: -100px;
    right: -50px;
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 750px;
  }

  .page-hero-content h1 {
    color: #fff;
    margin: var(--sp-md) 0;
  }

  .page-hero-subtitle {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
    margin-bottom: var(--sp-lg);
  }

  .hero-ctas {
    display: flex;
    gap: var(--sp-sm);
    flex-wrap: wrap;
  }

  /* EPISODES LIST */
  .episodes-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: var(--r-lg);
    overflow: hidden;
  }

  .episode-row {
    display: grid;
    grid-template-columns: 80px 1fr auto 50px;
    gap: var(--sp-md);
    align-items: center;
    padding: var(--sp-md) var(--sp-lg);
    background: #fff;
    transition: all var(--fast) var(--ease);
  }

  .episode-row:hover {
    background: rgba(31, 166, 160, 0.04);
  }

  .episode-number {
    display: flex;
    justify-content: center;
  }

  .episode-info h3 {
    font-size: 1.05rem;
    margin-bottom: 0.15rem;
  }

  .episode-guests {
    font-size: 0.85rem;
    color: var(--teal);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .episode-desc {
    font-size: 0.85rem;
    color: rgba(42, 47, 54, 0.6);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .episode-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .episode-date {
    font-size: 0.8rem;
    color: rgba(42, 47, 54, 0.5);
  }

  .episode-duration {
    font-size: 0.75rem;
    color: rgba(42, 47, 54, 0.4);
    font-weight: 500;
  }

  .episode-play {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--coral);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--med) var(--ease-bounce);
    flex-shrink: 0;
  }

  .episode-play:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(249, 115, 58, 0.4);
    color: #fff;
  }

  .episode-play svg {
    margin-left: 2px;
  }

  @media (max-width: 768px) {
    .episode-row {
      grid-template-columns: 1fr auto;
      gap: var(--sp-sm);
    }

    .episode-number {
      display: none;
    }

    .episode-meta {
      display: none;
    }
  }

  /* BRAND TAGS */
  .brand-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: var(--sp-md);
  }

  .brand-tag {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ink);
    padding: 0.5rem 1.2rem;
    background: #fff;
    border-radius: var(--r-pill);
    border: 1px solid var(--ash);
    transition: all var(--fast) var(--ease);
  }

  .brand-tag:hover {
    border-color: var(--teal);
    color: var(--teal);
    transform: translateY(-2px);
  }

  /* GUEST SECTION */
  .guest-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-2xl);
    align-items: center;
  }

  .guest-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
  }

  .stat-item {
    text-align: center;
    padding: var(--sp-lg);
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--r-lg);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.5rem;
    color: var(--coral);
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .listen-links {
    display: flex;
    gap: var(--sp-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .guest-grid {
      grid-template-columns: 1fr;
    }

    .guest-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
